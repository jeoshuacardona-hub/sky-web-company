<!DOCTYPE html>
<html lang="es" class="light-style layout-menu-fixed" dir="ltr" data-theme="theme-default" data-assets-path="/assets/" data-template="vertical-menu-template-free">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
  <title><%= typeof title !== 'undefined' && title ? title + ' - Sky Web' : 'Sky Web' %></title>
  
  <!-- ICONOS BOXICONS (CDN) -->
  <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
  
  <!-- SNEAT ASSETS -->
  <link rel="stylesheet" href="/assets/vendor/css/core.css" />
  <link rel="stylesheet" href="/assets/vendor/css/theme-default.css" />
  <link rel="stylesheet" href="/assets/css/demo.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="layout-wrapper layout-content-navbar">
    <div class="layout-container">
      <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
        <div class="app-brand demo">
          <a href="/" class="app-brand-link">
            <span class="app-brand-text demo menu-text fw-bolder ms-2">Sky Web</span>
          </a>
        </div>
        <div class="menu-inner-shadow"></div>
        <ul class="menu-inner py-1">
          
          <!-- Dashboard (Todos lo ven) -->
          <li class="menu-item <%= typeof title !== 'undefined' && title==='Dashboard' ? 'active' : '' %>">
            <a href="/dashboard" class="menu-link">
              <i class='menu-icon tf-icons bx bx-home-circle'></i><div>Dashboard</div>
            </a>
          </li>

          <!-- ================= ADMIN ONLY ================= -->
          <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') { %>
            <li class="menu-header small text-uppercase"><span class="menu-header-text">Administración</span></li>
            <li class="menu-item <%= typeof title !== 'undefined' && title==='Leads' ? 'active' : '' %>">
              <a href="/leads" class="menu-link"><i class='menu-icon tf-icons bx bx-target-lock'></i><div>Leads</div></a>
            </li>
            <li class="menu-item">
              <a href="/users" class="menu-link"><i class='menu-icon tf-icons bx bx-user-circle'></i><div>Usuarios</div></a>
            </li>
            <li class="menu-item">
              <a href="/reports" class="menu-link"><i class='menu-icon tf-icons bx bx-bar-chart'></i><div>Reportes</div></a>
            </li>
          <% } %>

          <!-- ================= COMERCIALES (Todos) ================= -->
          <li class="menu-header small text-uppercase"><span class="menu-header-text">Gestión Comercial</span></li>
          
          <!-- Leads: Admin ve todos, Comercial ve "Mis Leads" -->
          <li class="menu-item <%= typeof title !== 'undefined' && title==='Leads' ? 'active' : '' %>">
            <a href="/leads" class="menu-link">
              <i class='menu-icon tf-icons bx bx-target-lock'></i>
              <div><%= (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') ? 'Todos los Leads' : 'Mis Leads' %></div>
            </a>
          </li>
          
          <li class="menu-item <%= typeof title !== 'undefined' && title==='Llamadas' ? 'active' : '' %>">
            <a href="/llamadas" class="menu-link"><i class='menu-icon tf-icons bx bx-phone'></i><div>Llamadas</div></a>
          </li>
          <li class="menu-item <%= typeof title !== 'undefined' && title==='Seguimiento' ? 'active' : '' %>">
            <a href="/seguimiento" class="menu-link"><i class='menu-icon tf-icons bx bx-refresh'></i><div>Seguimiento</div></a>
          </li>
          <li class="menu-item <%= typeof title !== 'undefined' && title==='Pipeline' ? 'active' : '' %>">
            <a href="/pipeline" class="menu-link"><i class='menu-icon tf-icons bx bx-briefcase-alt'></i><div>Pipeline</div></a>
          </li>
          <li class="menu-item <%= typeof title !== 'undefined' && title==='Calendario' ? 'active' : '' %>">
            <a href="/calendar" class="menu-link"><i class='menu-icon tf-icons bx bx-calendar'></i><div>Calendario</div></a>
          </li>

          <!-- ================= ADMIN ONLY: Cuenta ================= -->
          <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') { %>
            <li class="menu-header small text-uppercase"><span class="menu-header-text">Cuenta</span></li>
            <li class="menu-item <%= typeof title !== 'undefined' && title==='Mi Perfil' ? 'active' : '' %>">
              <a href="/profile" class="menu-link"><i class='menu-icon tf-icons bx bx-user'></i><div>Mi Perfil</div></a>
            </li>
          <% } %>

          <!-- Logout (Todos) -->
          <li class="menu-item"><a href="/logout" class="menu-link"><i class='menu-icon tf-icons bx bx-log-out'></i><div>Cerrar Sesión</div></a></li>
          
        </ul>
      </aside>
      <div class="layout-page">
        <div class="content-wrapper">
          <div class="container-xxl flex-grow-1 container-p-y">
            <%- body %>
          </div>
        </div>
      </div>
    </div>
    <div class="layout-overlay layout-menu-toggle"></div>
  </div>
  
  <script src="/assets/vendor/libs/jquery/jquery.js"></script>
  <script src="/assets/vendor/libs/popper/popper.js"></script>
  <script src="/assets/vendor/js/bootstrap.js"></script>
  <script src="/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>
  <script src="/assets/vendor/js/menu.js"></script>
  <script src="/assets/js/main.js"></script>
</body>
</html>
