<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #0f172a; color: #fff; }
.calendar-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 24px 32px; display: flex; justify-content: space-between; align-items: center; }
.calendar-header h1 { font-size: 28px; font-weight: 700; }
.btn-primary { background: #fff; color: #667eea; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; }
.btn-primary:hover { background: #e2e8f0; }
.calendar-wrapper { background: #1e293b; border-radius: 16px; margin: 24px; overflow: hidden; }
.calendar-nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 32px; border-bottom: 1px solid #334155; }
.calendar-nav h2 { font-size: 24px; font-weight: 700; }
.nav-buttons { display: flex; gap: 12px; }
.btn-nav { background: #334155; color: #fff; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; }
.btn-nav:hover { background: #475569; }
.calendar-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); }
.day-header { background: #334155; color: #94a3b8; padding: 12px; text-align: center; font-weight: 600; font-size: 13px; text-transform: uppercase; border-right: 1px solid #1e293b; min-width: 0; }
.calendar-day { min-height: 120px; background: #1e293b; border-right: 1px solid #334155; border-bottom: 1px solid #334155; padding: 8px; cursor: pointer; transition: 0.2s; min-width: 0; }
.calendar-day:hover { background: #334155; }
.calendar-day.today { background: #1e3a5f; }
.calendar-day.other-month { background: #0f172a; opacity: 0.4; }
.day-number { font-size: 14px; font-weight: 600; color: #e2e8f0; margin-bottom: 8px; }
.calendar-day.today .day-number { background: #667eea; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; }
.event-item { background: #10b981; color: #fff; padding: 4px 6px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-bottom: 3px; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.event-item.task { background: #f59e0b; }
.event-item:hover { transform: scale(1.02); }
.stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px; margin: 24px 32px; }
.stat-card { background: #1e293b; padding: 16px; border-radius: 12px; text-align: center; }
.stat-card h3 { font-size: 28px; font-weight: 700; color: #667eea; }
.stat-card p { color: #94a3b8; font-size: 13px; }

/* 📱 MOBILE OVERRIDES */
@media (max-width: 768px) {
  .calendar-header { flex-direction: column; align-items: flex-start; gap: 12px; padding: 16px !important; }
  .btn-primary { width: 100%; text-align: center; }
  .calendar-wrapper { margin: 10px !important; }
  .calendar-nav { flex-direction: column; gap: 10px; align-items: stretch !important; padding: 12px !important; }
  .calendar-nav h2 { font-size: 18px !important; text-align: center; }
  .nav-buttons { justify-content: center; }
  
  .calendar-grid, .day-header { display: none !important; }
  .mobile-events { display: block !important; padding: 10px; }
  .mobile-event { background: #1e293b; border-radius: 10px; padding: 14px; margin-bottom: 10px; border-left: 4px solid #10b981; }
  .mobile-event.task { border-left-color: #f59e0b; }
  .mobile-event-title { font-weight: 600; font-size: 15px; margin-bottom: 4px; }
  .mobile-event-meta { font-size: 12px; color: #94a3b8; display: flex; flex-wrap: wrap; gap: 8px; }
  .mobile-event-desc { font-size: 13px; color: #cbd5e1; margin-top: 6px; }
  
  #modal { padding: 10px !important; }
  #modal > div { width: 100% !important; max-width: 100% !important; padding: 20px !important; margin: 0 !important; border-radius: 12px !important; }
  input, select, textarea, button { font-size: 14px !important; }
}

@media (min-width: 769px) {
  .mobile-events { display: none !important; }
}
</style>

<div class="calendar-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
  <h1>📅 Calendario</h1>
  <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
    <% if (isAdmin) { %>
      <% if (isGoogleConnected) { %>
        <div style="display: flex; align-items: center; gap: 8px; background: rgba(16, 185, 129, 0.2); border: 1px solid #10b981; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; color: #34d399;">
          <span style="display: inline-block; width: 8px; height: 8px; background: #10b981; border-radius: 50%;"></span>
          Google Calendar Sincronizado
          <a href="/auth/google/disconnect" style="color: #ef4444; margin-left: 8px; text-decoration: none; font-size: 11px; font-weight: 700;" onclick="return confirm('¿Desvincular Google Calendar?')">Desvincular</a>
        </div>
      <% } else { %>
        <a href="/auth/google" style="display: flex; align-items: center; gap: 8px; background: #ea4335; border: none; padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; color: #fff; text-decoration: none; cursor: pointer; transition: 0.2s;">
          <svg style="width: 16px; height: 16px; fill: currentColor;" viewBox="0 0 24 24"><path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-5.136 4.114-3.513 0-6.36-2.847-6.36-6.36s2.847-6.36 6.36-6.36c1.696 0 3.24.66 4.417 1.748L21.44 4.5A11.9 11.9 0 0 0 12.24 0C5.48 0 0 5.48 0 12.24s5.48 12.24 12.24 12.24c6.76 0 11.76-4.75 11.76-11.96 0-.756-.07-1.488-.22-2.235H12.24z"/></svg>
          Vincular Google Calendar
        </a>
      <% } %>
    <% } %>
    <button class="btn-primary" onclick="openModal()">+ Nueva Reunión</button>
  </div>
</div>

<div class="stats">
  <div class="stat-card"><h3><%= (meetings||[]).length %></h3><p>Reuniones</p></div>
  <div class="stat-card"><h3><%= (tasks||[]).length %></h3><p>Tareas</p></div>
  <div class="stat-card"><h3><%= ((meetings||[]).length + (tasks||[]).length) %></h3><p>Total Eventos</p></div>
  <div class="stat-card" style="text-align: left; padding: 16px 20px;">
    <h4 style="font-size: 13px; font-weight: 700; color: #667eea; margin-bottom: 8px; border-bottom: 1px solid #334155; padding-bottom: 4px; text-transform: uppercase;">🤝 Por Asesor</h4>
    <div style="max-height: 80px; overflow-y: auto;">
      <%
      var counts = {};
      (meetings || []).forEach(function(m) {
          if (m.createdBy) {
              var name = m.createdBy.fullName || m.createdBy.username;
              counts[name] = (counts[name] || 0) + 1;
          }
      });
      var sorted = Object.keys(counts).sort(function(a,b){ return counts[b] - counts[a]; });
      if (sorted.length === 0) {
      %>
        <p style="color: #94a3b8; font-size: 12px; margin: 0;">Sin reuniones agendadas</p>
      <% } else { %>
        <% sorted.forEach(function(name) { %>
          <div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;">
            <span style="font-weight: 600; color: #cbd5e1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 110px;">👤 <%= name %></span>
            <span style="background: rgba(102,126,234,0.2); color: #818cf8; padding: 1px 6px; border-radius: 10px; font-weight: 700;"><%= counts[name] %></span>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>
</div>

<div class="calendar-wrapper">
  <div class="calendar-nav">
    <div class="nav-buttons">
      <button class="btn-nav" onclick="changeMonth(-1)">← Anterior</button>
      <button class="btn-nav" onclick="goToday()">Hoy</button>
      <button class="btn-nav" onclick="changeMonth(1)">Siguiente →</button>
    </div>
    <h2 id="currentMonth">Mayo 2026</h2>
    <div style="width: 150px;"></div>
  </div>
  
  <div class="calendar-grid">
    <div class="day-header">Dom</div><div class="day-header">Lun</div><div class="day-header">Mar</div>
    <div class="day-header">Mié</div><div class="day-header">Jue</div><div class="day-header">Vie</div><div class="day-header">Sáb</div>
  </div>
  <div class="calendar-grid" id="calendarDays"></div>
  
  <!-- 📱 VISTA MÓVIL (Lista vertical) -->
  <div class="mobile-events" id="mobileEvents"></div>
</div>

<div id="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:99999; align-items:center; justify-content:center;">
  <div style="background:#1e293b; padding:30px; border-radius:16px; width:90%; max-width:500px; position:relative; box-shadow:0 20px 60px rgba(0,0,0,0.5);">
    <button onclick="closeModal()" style="position:absolute; top:15px; right:15px; background:#334155; border:none; color:#fff; width:32px; height:32px; border-radius:50%; cursor:pointer; font-size:18px;">✕</button>
    <h3 id="modalTitle" style="margin-bottom:20px; font-size:22px;">📅 Nueva Reunión</h3>
    <form id="eventForm" onsubmit="saveEvent(event)">
      <input type="hidden" id="eventId">
      <div id="creatorSection" style="margin-bottom:15px; display:none;">
        <label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Agendado por</label>
        <div id="eventCreator" style="padding:10px; background:#0f172a; border:1px solid #334155; color:#fff; border-radius:8px; font-size:13px; font-weight:600;"></div>
      </div>
      <div id="meetSection" style="margin-bottom:15px; display:none;">
        <label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Google Meet</label>
        <a id="eventMeetLink" href="#" target="_blank" style="display:inline-flex; align-items:center; gap:8px; color:#34d399; font-weight:600; font-size:13px; text-decoration:none; background:rgba(16,185,129,0.15); padding:10px; border-radius:8px; border:1px dashed #10b981; width:100%;">
          <svg style="width:18px; height:18px; fill:currentColor;" viewBox="0 0 24 24"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4zM14 16H5V8h9v8z"/></svg>
          Entrar a la videollamada de Meet
        </a>
      </div>
      <div style="margin-bottom:15px;"><label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Título *</label><input type="text" id="title" required style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:#fff; border-radius:8px;"></div>

      <div style="margin-bottom:15px;"><label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Fecha *</label><input type="date" id="date" required style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:#fff; border-radius:8px;"></div>
      <div style="display: flex; gap: 15px; margin-bottom: 15px;">
        <div style="flex: 1;">
          <label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Hora Inicio *</label>
          <input type="time" id="time" required style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:#fff; border-radius:8px;">
        </div>
        <% if (isAdmin) { %>
        <div style="flex: 1;">
          <label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Hora Fin (Opcional)</label>
          <input type="time" id="endTime" style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:#fff; border-radius:8px;">
        </div>
        <% } %>
      </div>
      <div style="margin-bottom:15px;"><label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Tipo</label><select id="type" style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:#fff; border-radius:8px;"><option value="meeting">Reunión</option><option value="task">Tarea</option></select></div>
      <div style="margin-bottom:15px;"><label style="display:block; margin-bottom:5px; color:#94a3b8; font-size:13px;">Descripción</label><textarea id="description" rows="3" style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:#fff; border-radius:8px;"></textarea></div>
      <button type="submit" style="width:100%; padding:12px; background:#667eea; color:#fff; border:none; border-radius:8px; font-weight:600; cursor:pointer; margin-bottom:10px;">💾 Guardar</button>
      <button type="button" id="deleteBtn" onclick="deleteEvent()" style="width:100%; padding:12px; background:#ef4444; color:#fff; border:none; border-radius:8px; font-weight:600; cursor:pointer;">🗑️ Eliminar</button>
    </form>
  </div>
</div>

<!-- Modal de detalles del día -->
<div id="dayEventsModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:9999; align-items:center; justify-content:center;">
  <div style="background:#1e293b; padding:30px; border-radius:16px; width:90%; max-width:500px; position:relative; box-shadow:0 20px 60px rgba(0,0,0,0.5);">
    <button onclick="closeDayEventsModal()" style="position:absolute; top:15px; right:15px; background:#334155; border:none; color:#fff; width:32px; height:32px; border-radius:50%; cursor:pointer; font-size:18px;">✕</button>
    <h3 id="dayEventsModalTitle" style="margin-bottom:20px; font-size:20px; color:#fff;">📅 Eventos del día</h3>
    
    <div id="dayEventsList" style="max-height:300px; overflow-y:auto; margin-bottom:20px; display:flex; flex-direction:column; gap:10px;">
        <!-- Se rellena dinámicamente -->
    </div>
    
    <button id="addEventFromDayBtn" style="width:100%; padding:12px; background:#667eea; color:#fff; border:none; border-radius:8px; font-weight:600; cursor:pointer;">+ Nueva Reunión</button>
  </div>
</div>

<%
function safeDateStr(d) {
    if (!d) return '';
    try {
        const dateObj = new Date(d);
        if (isNaN(dateObj.getTime())) return '';
        return dateObj.toISOString().split('T')[0];
    } catch(e) {
        return '';
    }
}
%>
<script>
let currentDate = new Date();
const meetingsData = <%- JSON.stringify((meetings||[]).map(m => ({ _id: m._id, title: m.title + ' (' + (m.createdBy ? (m.createdBy.fullName || m.createdBy.username) : 'Asesor') + ')', date: safeDateStr(m.date), time: m.time, type: 'meeting', description: m.description || '', meetLink: m.meetLink || '' }))) %>;
const tasksData = <%- JSON.stringify((tasks||[]).map(t => ({ _id: t._id, title: t.title, date: safeDateStr(t.dueDate || t.createdAt), type: 'task', description: t.description || '' }))) %>;

function handleDayClick(dateStr) {
  const dayMeetings = meetingsData.filter(m => m.date === dateStr);
  const dayTasks = tasksData.filter(t => t.date === dateStr);
  const dayEvents = [...dayMeetings, ...dayTasks];
  
  if (dayEvents.length === 0) {
    openModal(dateStr);
  } else {
    openDayEventsModal(dateStr, dayEvents);
  }
}

function openDayEventsModal(dateStr, events) {
  const list = document.getElementById('dayEventsList');
  list.innerHTML = '';
  
  const dateParts = dateStr.split('-');
  const dateObj = new Date(dateParts[0], dateParts[1] - 1, dateParts[2]);
  const options = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
  document.getElementById('dayEventsModalTitle').textContent = '📅 ' + dateObj.toLocaleDateString('es-ES', options);
  
  events.forEach(e => {
    const item = document.createElement('div');
    item.style.cssText = 'background:#0f172a; padding:12px; border-radius:8px; border-left:4px solid ' + (e.type === 'task' ? '#f59e0b' : '#10b981') + '; cursor:pointer; transition:0.2s;';
    item.onclick = (event) => {
      event.stopPropagation();
      closeDayEventsModal();
      editEvent(e._id, e.type);
    };
    item.onmouseover = () => { item.style.background = '#1e293b'; };
    item.onmouseout = () => { item.style.background = '#0f172a'; };
    
    const meetButton = e.meetLink ? `<a href="${e.meetLink}" target="_blank" onclick="event.stopPropagation();" style="display:inline-flex; align-items:center; gap:6px; background:#10b981; color:#fff; padding:6px 12px; border-radius:6px; font-size:11px; text-decoration:none; font-weight:700; margin-top:8px; width:fit-content;">🎥 Unirse a Google Meet</a>` : '';
    
    item.innerHTML = `
      <div style="font-weight:600; font-size:13px; color:#fff; margin-bottom:4px;">${e.title}</div>
      <div style="font-size:11px; color:#94a3b8;">
        ${e.time ? '⏰ ' + e.time + ' | ' : ''} ${e.type === 'task' ? '📝 Tarea' : '🤝 Reunión'}
      </div>
      ${meetButton}
    `;
    list.appendChild(item);
  });
  
  document.getElementById('addEventFromDayBtn').onclick = () => {
    closeDayEventsModal();
    openModal(dateStr);
  };
  
  document.getElementById('dayEventsModal').style.display = 'flex';
}

function closeDayEventsModal() {
  document.getElementById('dayEventsModal').style.display = 'none';
}

function renderCalendar() {
  const year = currentDate.getFullYear();
  const month = currentDate.getMonth();
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const monthNames = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  document.getElementById('currentMonth').textContent = `${monthNames[month]} ${year}`;
  
  const grid = document.getElementById('calendarDays');
  const mobileList = document.getElementById('mobileEvents');
  grid.innerHTML = '';
  mobileList.innerHTML = '';
  
  const today = new Date();
  const isCurrentMonth = today.getMonth() === month && today.getFullYear() === year;
  
  // Desktop Grid
  for (let i = 0; i < firstDay; i++) grid.innerHTML += '<div class="calendar-day other-month"></div>';
  
  // Combine & sort all events for mobile list
  const allEvents = [...meetingsData, ...tasksData].sort((a,b) => new Date(a.date) - new Date(b.date));
  
  for (let day = 1; day <= daysInMonth; day++) {
    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const isToday = isCurrentMonth && day === today.getDate();
    const dayMeetings = meetingsData.filter(m => m.date === dateStr);
    const dayTasks = tasksData.filter(t => t.date === dateStr);
    const dayEvents = [...dayMeetings, ...dayTasks];
    
    let eventsHtml = dayEvents.map(e => `<div class="event-item ${e.type}" onclick="event.stopPropagation(); editEvent('${e._id}', '${e.type}')">${e.time ? e.time+' ' : ''}${e.title}</div>`).join('');
    grid.innerHTML += `<div class="calendar-day ${isToday ? 'today' : ''}" onclick="openModal('${dateStr}')"><div class="day-number">${day}</div><div>${eventsHtml}</div></div>`;
  }
  
  // Mobile List
  if (allEvents.length === 0) {
    mobileList.innerHTML = '<div style="text-align:center;padding:30px;color:#94a3b8;">No hay eventos este mes</div>';
  } else {
    allEvents.forEach(ev => {
      mobileList.innerHTML += `
        <div class="mobile-event ${ev.type}" onclick="editEvent('${ev._id}', '${ev.type}')">
          <div class="mobile-event-title">${ev.title}</div>
          <div class="mobile-event-meta">
            <span>📅 ${new Date(ev.date).toLocaleDateString('es-CO')}</span>
            ${ev.time ? `<span>⏰ ${ev.time}</span>` : ''}
            <span>${ev.type === 'task' ? '📝 Tarea' : '🤝 Reunión'}</span>
          </div>
          ${ev.description ? `<div class="mobile-event-desc">${ev.description}</div>` : ''}
        </div>
      `;
    });
  }
}

function changeMonth(delta) { currentDate.setMonth(currentDate.getMonth() + delta); renderCalendar(); }
function goToday() { currentDate = new Date(); renderCalendar(); }

function openModal(date = null) {
  document.getElementById('modal').style.display = 'flex';
  document.getElementById('eventForm').reset();
  document.getElementById('eventId').value = '';
  document.getElementById('modalTitle').textContent = '📅 Nueva Reunión';
  document.getElementById('deleteBtn').style.display = 'none';
  document.getElementById('date').value = date || new Date().toISOString().split('T')[0];
  document.getElementById('creatorSection').style.display = 'none';
  const meetSec = document.getElementById('meetSection');
  if (meetSec) meetSec.style.display = 'none';
  
  const endTimeEl = document.getElementById('endTime');
  if (endTimeEl) endTimeEl.value = '';
}

function closeModal() { document.getElementById('modal').style.display = 'none'; }

async function saveEvent(e) {
  e.preventDefault();
  const id = document.getElementById('eventId').value;
  
  let timeVal = document.getElementById('time').value;
  const typeVal = document.getElementById('type').value;
  
  if (typeVal === 'meeting' && timeVal) {
      const endTimeEl = document.getElementById('endTime');
      if (endTimeEl && endTimeEl.value) {
          timeVal = timeVal + ' - ' + endTimeEl.value;
      } else {
          const parts = timeVal.split(':');
          let hour = parseInt(parts[0], 10);
          let minute = parts[1];
          let endHour = (hour + 1) % 24;
          const endHourStr = String(endHour).padStart(2, '0');
          timeVal = timeVal + ' - ' + endHourStr + ':' + minute;
      }
  }
  
  const data = {
    title: document.getElementById('title').value,
    date: document.getElementById('date').value,
    time: timeVal,
    type: typeVal,
    description: document.getElementById('description').value
  };
  try {
    const url = id ? `/calendar/update/${id}` : '/calendar/save';
    const response = await fetch(url, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
    if (!response.ok) {
        const errData = await response.json();
        throw new Error(errData.error || errData.message || 'Error al guardar');
    }
    location.reload();
  } catch(err) { alert(err.message); }
}

async function editEvent(id, type) {
  try {
    const res = await fetch(`/calendar/event/${id}?type=${type}`);
    if (!res.ok) throw new Error('Failed');
    const ev = await res.json();
    if (!ev || !ev._id) throw new Error('Not found');
    document.getElementById('modalTitle').textContent = '✏️ Editar Evento';
    document.getElementById('eventId').value = ev._id;
    document.getElementById('title').value = ev.title || '';
    document.getElementById('date').value = ev.date ? new Date(ev.date).toISOString().split('T')[0] : '';
    
    let startTimeVal = ev.time || '';
    let endTimeVal = '';
    if (startTimeVal.includes(' - ')) {
        const parts = startTimeVal.split(' - ');
        startTimeVal = parts[0];
        endTimeVal = parts[1];
    }
    document.getElementById('time').value = startTimeVal;
    const endTimeEl = document.getElementById('endTime');
    if (endTimeEl) {
        endTimeEl.value = endTimeVal;
    }
    
    document.getElementById('type').value = type;
    document.getElementById('description').value = ev.description || '';
    document.getElementById('deleteBtn').style.display = 'block';
    
    const creatorSec = document.getElementById('creatorSection');
    const creatorEl = document.getElementById('eventCreator');
    if (ev.createdBy) {
      creatorEl.textContent = '👤 ' + (ev.createdBy.fullName || ev.createdBy.username);
      creatorSec.style.display = 'block';
    } else {
      creatorSec.style.display = 'none';
    }
    
    const meetSec = document.getElementById('meetSection');
    const meetEl = document.getElementById('eventMeetLink');
    if (ev.meetLink && meetSec && meetEl) {
      meetEl.href = ev.meetLink;
      meetSec.style.display = 'block';
    } else if (meetSec) {
      meetSec.style.display = 'none';
    }
    
    document.getElementById('modal').style.display = 'flex';
  } catch(err) { alert('Error cargando: ' + err.message); }
}

async function deleteEvent() {
  const id = document.getElementById('eventId').value;
  const type = document.getElementById('type').value;
  if (!id || !confirm('¿Eliminar?')) return;
  window.location.href = `/calendar/delete/${id}?type=${type}`;
}

document.getElementById('modal').addEventListener('click', e => { if(e.target.id === 'modal') closeModal(); });
document.getElementById('dayEventsModal').addEventListener('click', e => { if(e.target.id === 'dayEventsModal') closeDayEventsModal(); });
document.addEventListener('keydown', e => { 
  if(e.key === 'Escape') { 
    closeModal(); 
    closeDayEventsModal(); 
  } 
});
document.addEventListener('DOMContentLoaded', renderCalendar);
</script>
