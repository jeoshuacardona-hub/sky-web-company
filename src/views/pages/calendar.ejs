<style>
.container { max-width: 1200px; margin: 0 auto; padding: 20px; }
.btn { display: inline-block; padding: 10px 20px; background: #667eea; color: #fff; text-decoration: none; border-radius: 8px; margin: 5px; }
.btn:hover { background: #764ba2; }
.card { background: #fff; padding: 20px; border-radius: 12px; margin: 10px 0; box-shadow: 0 2px 8px rgba(0,0,0,0.1); cursor: pointer; }
.card:hover { transform: translateX(5px); }
</style>
<div class="container">
  <h1>📅 Calendario</h1>
  <a href="/calendar/new" class="btn">+ Nueva Reunión</a>
  
  <h2 style="margin-top: 30px;">Mis Reuniones</h2>
  <% if (meetings.length === 0) { %>
    <p style="color: #666; padding: 20px;">No hay reuniones agendadas</p>
  <% } else { %>
    <% meetings.forEach(m => { %>
      <div class="card" onclick="window.location='/calendar/edit/<%= m._id %>'">
        <h3><%= m.title %></h3>
        <p>📅 <%= new Date(m.date).toLocaleDateString('es-CO') %> ⏰ <%= m.time %></p>
        <% if (m.description) { %><p><%= m.description %></p><% } %>
        <div style="margin-top: 10px;">
          <a href="/calendar/edit/<%= m._id %>" class="btn" style="background: #f59e0b;">✏️ Editar</a>
          <a href="/calendar/delete/<%= m._id %>" class="btn" style="background: #ef4444;" onclick="event.stopPropagation(); return confirm('¿Eliminar?')">🗑️ Eliminar</a>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
