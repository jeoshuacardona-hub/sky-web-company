<style>
.calendar-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px;
}

.calendar-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16px;
  padding: 30px;
  color: #fff;
  margin-bottom: 30px;
}

.calendar-header h1 {
  font-size: 32px;
  font-weight: 700;
  margin: 0 0 10px;
}

.calendar-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  margin-bottom: 30px;
}

.stat-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  gap: 16px;
}

.stat-icon {
  width: 50px;
  height: 50px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stat-info h3 {
  font-size: 28px;
  font-weight: 700;
  margin: 0;
  color: #1a202c;
}

.stat-info p {
  font-size: 13px;
  color: #718096;
  margin: 4px 0 0;
}

.events-list {
  display: grid;
  gap: 16px;
}

.event-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  border-left: 4px solid #667eea;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  transition: all 0.3s;
}

.event-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}

.event-card.type-call {
  border-left-color: #16a34a;
}

.event-card.type-task {
  border-left-color: #f59e0b;
}

.event-header {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 12px;
}

.event-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.event-card.type-call .event-icon {
  background: #dcfce7;
  color: #16a34a;
}

.event-card.type-task .event-icon {
  background: #fef3c7;
  color: #f59e0b;
}

.event-title {
  flex: 1;
  font-size: 18px;
  font-weight: 700;
  color: #1a202c;
  margin: 0 0 4px;
}

.event-meta {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  font-size: 13px;
  color: #718096;
}

.event-meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
}

.event-meta-item i {
  font-size: 14px;
}

.badge-event {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.badge-call { background: #dcfce7; color: #16a34a; }
.badge-task { background: #fef3c7; color: #f59e0b; }
.badge-priority-high { background: #fee2e2; color: #dc2626; }
.badge-priority-medium { background: #fef3c7; color: #f59e0b; }
.badge-priority-low { background: #dcfce7; color: #16a34a; }

.empty-state {
  text-align: center;
  padding: 60px 20px;
  background: #fff;
  border-radius: 16px;
}

.empty-state-icon {
  width: 100px;
  height: 100px;
  background: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}

.empty-state-icon i {
  font-size: 48px;
  color: #9ca3af;
}
</style>

<div class="calendar-container">
  <div class="calendar-header">
    <h1><i class="bx bx-calendar me-3"></i>Calendario</h1>
    <p style="margin:0;opacity:0.9;font-size:16px;">Gestiona tus llamadas y tareas programadas</p>
  </div>
  
  <div class="calendar-stats">
    <div class="stat-card">
      <div class="stat-icon" style="background:#dcfce7;">
        <i class="bx bx-phone" style="font-size:24px;color:#16a34a;"></i>
      </div>
      <div class="stat-info">
        <h3><%= scheduledCalls.length %></h3>
        <p>Llamadas Agendadas</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#fef3c7;">
        <i class="bx bx-task" style="font-size:24px;color:#f59e0b;"></i>
      </div>
      <div class="stat-info">
        <h3><%= tasks.length %></h3>
        <p>Tareas Pendientes</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#e0e7ff;">
        <i class="bx bx-calendar-check" style="font-size:24px;color:#6366f1;"></i>
      </div>
      <div class="stat-info">
        <h3><%= events.length %></h3>
        <p>Total Eventos</p>
      </div>
    </div>
  </div>
  
  <% if (events.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">
        <i class="bx bx-calendar-x"></i>
      </div>
      <h3 style="font-weight:700;color:#1a202c;margin-bottom:8px;">No hay eventos programados</h3>
      <p style="color:#718096;margin-bottom:20px;">Aún no tienes llamadas o tareas agendadas</p>
      <% if (isAdmin) { %>
        <a href="/leads" class="btn btn-primary">
          <i class="bx bx-plus me-2"></i>Crear Lead y Agendar
        </a>
      <% } else { %>
        <a href="/llamadas" class="btn btn-primary">
          <i class="bx bx-phone me-2"></i>Ir a Llamadas
        </a>
      <% } %>
    </div>
  <% } else { %>
    <div class="events-list">
      <% events.forEach(function(event) { %>
        <div class="event-card type-<%= event.type %>">
          <div class="event-header">
            <div class="event-icon">
              <i class="bx <%= event.type === 'call' ? 'bx-phone' : 'bx-task' %>"></i>
            </div>
            <div style="flex:1;">
              <h3 class="event-title"><%= event.title %></h3>
              <div class="event-meta">
                <div class="event-meta-item">
                  <i class="bx bx-calendar"></i>
                  <span><%= new Date(event.date).toLocaleDateString('es-CO', {weekday:'long', year:'numeric', month:'long', day:'numeric'}) %></span>
                </div>
                <div class="event-meta-item">
                  <i class="bx bx-time"></i>
                  <span><%= new Date(event.date).toLocaleTimeString('es-CO', {hour:'2-digit', minute:'2-digit'}) %></span>
                </div>
                <% if (event.type === 'task' && event.priority) { %>
                  <span class="badge-event badge-priority-<%= event.priority %>">
                    <%= event.priority %>
                  </span>
                <% } %>
                <span class="badge-event badge-<%= event.type %>">
                  <%= event.type === 'call' ? 'Llamada' : 'Tarea' %>
                </span>
              </div>
            </div>
          </div>
          <% if (event.description) { %>
            <p style="color:#4a5568;margin:12px 0 0;font-size:14px;line-height:1.5;">
              <i class="bx bx-comment me-1"></i><%= event.description %>
            </p>
          <% } %>
          <% if (event.lead) { %>
            <div style="margin-top:12px;padding-top:12px;border-top:1px solid #e2e8f0;">
              <div style="font-size:13px;color:#718096;">
                <i class="bx bx-user me-1"></i>
                <%= event.lead.name %>
                <% if (event.lead.phone) { %>
                  <span style="margin-left:12px;">
                    <i class="bx bx-phone me-1"></i><%= event.lead.phone %>
                  </span>
                <% } %>
              </div>
            </div>
          <% } %>
          <% if (event.assignedTo) { %>
            <div style="margin-top:12px;padding-top:12px;border-top:1px solid #e2e8f0;">
              <div style="font-size:13px;color:#718096;">
                <i class="bx bx-user me-1"></i>
                Asignado a: <%= event.assignedTo.fullName || event.assignedTo.username %>
              </div>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
