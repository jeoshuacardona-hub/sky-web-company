<style>
.messages-container { display: grid; grid-template-columns: 300px 1fr; gap: 24px; height: calc(100vh - 200px); }
.messages-sidebar { background: #fff; border-radius: 12px; padding: 16px; overflow-y: auto; }
.messages-main { background: #fff; border-radius: 12px; padding: 24px; display: flex; flex-direction: column; }
.user-list-item { padding: 12px; border-radius: 8px; cursor: pointer; transition: 0.2s; margin-bottom: 8px; }
.user-list-item:hover { background: #f8fafc; }
.user-list-item.active { background: #f0f0ff; }
.user-list-item .unread-badge { background: #ef4444; color: #fff; padding: 2px 8px; border-radius: 10px; font-size: 11px; margin-left: 8px; }
.message-bubble { max-width: 70%; padding: 12px 16px; border-radius: 12px; margin-bottom: 12px; }
.message-bubble.sent { background: #667eea; color: #fff; margin-left: auto; }
.message-bubble.received { background: #f1f5f9; color: #1e293b; }
.message-time { font-size: 11px; opacity: 0.7; margin-top: 4px; }
.message-input-area { display: flex; gap: 12px; margin-top: auto; padding-top: 16px; border-top: 1px solid #e2e8f0; }
.message-input { flex: 1; padding: 12px; border: 1px solid #d9dee3; border-radius: 8px; }
</style>

<div class="messages-container">
  <div class="messages-sidebar">
    <h3 style="margin:0 0 16px 0; font-size:18px; font-weight:700;">Conversaciones</h3>
    <% users.forEach(u => { %>
      <div class="user-list-item" onclick="loadConversation('<%= u._id %>', '<%= u.fullName || u.username %>')">
        <strong><%= u.fullName || u.username %></strong>
        <% if (conversations[u._id.toString()] && conversations[u._id.toString()].unread > 0) { %>
          <span class="unread-badge"><%= conversations[u._id.toString()].unread %></span>
        <% } %>
      </div>
    <% }) %>
  </div>
  
  <div class="messages-main" id="messagesMain">
    <div style="text-align:center; padding:60px 20px; color:#64748b;">
      <i class='bx bx-message-detail' style="font-size:48px; opacity:0.3;"></i>
      <p style="margin-top:16px;">Selecciona un usuario para ver la conversación</p>
    </div>
  </div>
</div>

<script>
let currentUserId = null;

async function loadConversation(userId, userName) {
  currentUserId = userId;
  document.querySelectorAll('.user-list-item').forEach(item => item.classList.remove('active'));
  event.target.closest('.user-list-item').classList.add('active');
  
  document.getElementById('messagesMain').innerHTML = `
    <h3 style="margin:0 0 16px 0;">${userName}</h3>
    <div id="messagesList" style="flex:1; overflow-y:auto; margin-bottom:16px;"></div>
    <div class="message-input-area">
      <input type="text" id="messageInput" class="message-input" placeholder="Escribe un mensaje..." onkeypress="if(event.key==='Enter')sendMessage()">
      <button class="btn btn-primary" onclick="sendMessage()">Enviar</button>
    </div>
  `;
  
  const res = await fetch('/api/messages/' + userId);
  const data = await res.json();
  
  if (data.success) {
    const messagesList = document.getElementById('messagesList');
    data.messages.forEach(msg => {
      const isSent = msg.sender === '<%= currentUser._id %>';
      messagesList.innerHTML += `
        <div class="message-bubble ${isSent ? 'sent' : 'received'}">
          ${msg.message}
          <div class="message-time">${new Date(msg.createdAt).toLocaleTimeString('es-CO', {hour:'2-digit', minute:'2-digit'})}</div>
        </div>
      `;
    });
    messagesList.scrollTop = messagesList.scrollHeight;
  }
}

async function sendMessage() {
  const input = document.getElementById('messageInput');
  const message = input.value.trim();
  if (!message || !currentUserId) return;
  
  const res = await fetch('/api/messages', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ receiver: currentUserId, message })
  });
  
  const data = await res.json();
  if (data.success) {
    input.value = '';
    loadConversation(currentUserId, '');
  }
}
</script>
