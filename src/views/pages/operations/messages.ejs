<style>
.messages-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 24px 32px; color: #fff; margin-bottom: 24px; }
.messages-header h1 { margin: 0 0 8px 0; font-size: 28px; font-weight: 700; }
.messages-container { display: grid; grid-template-columns: 300px 1fr; gap: 24px; height: calc(100vh - 280px); min-height: 500px; }
.messages-sidebar { background: #fff; border-radius: 12px; padding: 16px; overflow-y: auto; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.messages-main { background: #fff; border-radius: 12px; padding: 24px; display: flex; flex-direction: column; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.user-list-item { padding: 12px; border-radius: 8px; cursor: pointer; transition: 0.2s; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
.user-list-item:hover { background: #f8fafc; }
.user-list-item.active { background: #f0f0ff; border-left: 3px solid #667eea; }
.user-list-item .unread-badge { background: #ef4444; color: #fff; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 700; }
.message-bubble { max-width: 70%; padding: 12px 16px; border-radius: 12px; margin-bottom: 12px; word-wrap: break-word; }
.message-bubble.sent { background: #667eea; color: #fff; margin-left: auto; border-bottom-right-radius: 4px; }
.message-bubble.received { background: #f1f5f9; color: #1e293b; border-bottom-left-radius: 4px; }
.message-time { font-size: 10px; opacity: 0.7; margin-top: 4px; }
.message-input-area { display: flex; gap: 12px; margin-top: auto; padding-top: 16px; border-top: 1px solid #e2e8f0; }
.message-input { flex: 1; padding: 12px 16px; border: 2px solid #e2e8f0; border-radius: 24px; font-size: 14px; transition: 0.2s; }
.message-input:focus { outline: none; border-color: #667eea; }
.btn-send { background: #667eea; color: #fff; border: none; padding: 12px 24px; border-radius: 24px; font-weight: 600; cursor: pointer; transition: 0.2s; }
.btn-send:hover { background: #5a67d8; }
.messages-empty { text-align: center; padding: 60px 20px; color: #64748b; }
.messages-empty i { font-size: 64px; opacity: 0.3; display: block; margin-bottom: 16px; }
.conversation-header { padding-bottom: 16px; border-bottom: 1px solid #e2e8f0; margin-bottom: 16px; }
.conversation-header h3 { margin: 0; font-size: 18px; font-weight: 700; color: #1e293b; }
.messages-list { flex: 1; overflow-y: auto; padding: 8px 0; }
@media (max-width: 768px) {
  .messages-container { grid-template-columns: 1fr; }
  .messages-sidebar { max-height: 300px; }
}
</style>

<div class="messages-header">
  <h1>💬 Mensajes Internos</h1>
  <p>Comunicación directa con el equipo</p>
</div>

<div class="messages-container">
  <div class="messages-sidebar">
    <h3 style="margin:0 0 16px 0; font-size:16px; font-weight:700; color:#1e293b;">Conversaciones</h3>
    <% if (users && users.length > 0) { %>
      <% users.forEach(u => { 
        var userId = u._id.toString();
        var conv = conversations[userId];
        var unread = conv ? conv.unread : 0;
      %>
        <div class="user-list-item" data-user-id="<%= userId %>" data-user-name="<%= u.fullName || u.username %>" onclick="selectUser(this)">
          <div>
            <strong style="font-size:14px;"><%= u.fullName || u.username %></strong>
            <% if (conv && conv.messages.length > 0) { %>
              <div style="font-size:11px; color:#64748b; margin-top:2px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:180px;">
                <%= conv.messages[0].message.substring(0, 40) %>
              </div>
            <% } %>
          </div>
          <% if (unread > 0) { %>
            <span class="unread-badge"><%= unread %></span>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p style="color:#64748b; text-align:center; padding:20px;">No hay otros usuarios</p>
    <% } %>
  </div>
  
  <div class="messages-main" id="messagesMain">
    <div class="messages-empty">
      <i class='bx bx-message-detail'></i>
      <p style="font-size:16px; font-weight:600;">Selecciona una conversación</p>
      <p style="font-size:13px;">Elige un usuario de la lista para empezar a chatear</p>
    </div>
  </div>
</div>

<script>
var currentUserId = null;
var currentUserName = null;
var refreshInterval = null;
var CURRENT_USER_ID = '<%= currentUser._id.toString() %>';

function selectUser(element) {
  currentUserId = element.getAttribute('data-user-id');
  currentUserName = element.getAttribute('data-user-name');
  
  document.querySelectorAll('.user-list-item').forEach(item => item.classList.remove('active'));
  element.classList.add('active');
  
  // Quitar badge de no leídos
  var badge = element.querySelector('.unread-badge');
  if (badge) badge.remove();
  
  loadConversation();
  
  // Auto-refresh cada 5 segundos
  if (refreshInterval) clearInterval(refreshInterval);
  refreshInterval = setInterval(loadConversation, 5000);
}

async function loadConversation() {
  if (!currentUserId) return;
  
  var main = document.getElementById('messagesMain');
  
  // Preservar scroll si ya existe
  var existingList = document.getElementById('messagesList');
  var wasAtBottom = false;
  if (existingList) {
    wasAtBottom = existingList.scrollHeight - existingList.scrollTop - existingList.clientHeight < 50;
  }
  
  try {
    var res = await fetch('/api/messages/' + currentUserId);
    var data = await res.json();
    
    if (data.success) {
      var html = '<div class="conversation-header"><h3>' + escapeHtml(currentUserName) + '</h3></div>';
      html += '<div class="messages-list" id="messagesList">';
      
      if (data.messages.length === 0) {
        html += '<div class="messages-empty"><p style="font-size:14px;">Aún no hay mensajes en esta conversación</p></div>';
      } else {
        data.messages.forEach(function(msg) {
          var isSent = msg.sender.toString() === CURRENT_USER_ID;
          var time = new Date(msg.createdAt).toLocaleTimeString('es-CO', {hour:'2-digit', minute:'2-digit'});
          html += '<div class="message-bubble ' + (isSent ? 'sent' : 'received') + '">';
          html += escapeHtml(msg.message);
          html += '<div class="message-time">' + time + '</div>';
          html += '</div>';
        });
      }
      
      html += '</div>';
      html += '<div class="message-input-area">';
      html += '<input type="text" id="messageInput" class="message-input" placeholder="Escribe un mensaje..." onkeypress="if(event.key===\'Enter\')sendMessage()">';
      html += '<button class="btn-send" onclick="sendMessage()"><i class="bx bx-send"></i> Enviar</button>';
      html += '</div>';
      
      main.innerHTML = html;
      
      // Auto-scroll al final
      var messagesList = document.getElementById('messagesList');
      if (messagesList && (wasAtBottom || !existingList)) {
        messagesList.scrollTop = messagesList.scrollHeight;
      }
      
      // Focus en input
      var input = document.getElementById('messageInput');
      if (input && !existingList) input.focus();
    }
  } catch(err) {
    console.error('Error cargando conversación:', err);
  }
}

async function sendMessage() {
  var input = document.getElementById('messageInput');
  var message = input.value.trim();
  if (!message || !currentUserId) return;
  
  input.value = '';
  input.disabled = true;
  
  try {
    var res = await fetch('/api/messages', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ receiver: currentUserId, message: message })
    });
    
    var data = await res.json();
    if (data.success) {
      await loadConversation();
    } else {
      alert('Error: ' + (data.message || 'No se pudo enviar'));
    }
  } catch(err) {
    alert('Error de conexión: ' + err.message);
  } finally {
    input.disabled = false;
    input.focus();
  }
}

function escapeHtml(str) {
  if (!str) return '';
  var div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// Auto-abrir conversación si viene de la URL
window.addEventListener('load', function() {
  var params = new URLSearchParams(window.location.search);
  var userId = params.get('user');
  if (userId) {
    var item = document.querySelector('[data-user-id="' + userId + '"]');
    if (item) selectUser(item);
  }
});
</script>
