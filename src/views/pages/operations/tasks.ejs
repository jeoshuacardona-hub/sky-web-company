<style>
.task-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 24px 32px; color: #fff; margin-bottom: 24px; }
.task-header h1 { margin: 0 0 8px 0; font-size: 28px; font-weight: 700; }
.task-list { display: flex; flex-direction: column; gap: 16px; }
.task-card { background: #fff; border-radius: 12px; padding: 20px; border-left: 4px solid #667eea; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.task-card.priority-alta { border-left-color: #ef4444; }
.task-card.priority-media { border-left-color: #f59e0b; }
.task-card.priority-baja { border-left-color: #22c55e; }
.task-title { font-size: 16px; font-weight: 700; color: #1e293b; margin-bottom: 8px; }
.task-meta { display: flex; gap: 16px; font-size: 12px; color: #64748b; margin-bottom: 12px; flex-wrap: wrap; }
.task-actions { display: flex; gap: 8px; margin-top: 12px; }
.btn-task { padding: 6px 12px; border-radius: 6px; border: none; font-size: 12px; font-weight: 600; cursor: pointer; }
.btn-complete { background: #dcfce7; color: #22c55e; }
.btn-progress { background: #dbeafe; color: #3b82f6; }
</style>

<div class="task-header">
  <h1>✅ Gestión de Tareas</h1>
  <p>Asignación y seguimiento de tareas del equipo</p>
</div>

<button class="btn btn-primary mb-4" onclick="openNewTaskModal()">
  <i class='bx bx-plus'></i> Nueva Tarea
</button>

<div class="task-list">
  <% if (tasks && tasks.length > 0) { %>
    <% tasks.forEach(task => { %>
      <div class="task-card priority-<%= task.priority %>">
        <div class="task-title"><%= task.title %></div>
        <div class="task-meta">
          <div><i class='bx bx-user'></i> <%= task.assignedTo.fullName || task.assignedTo.username %></div>
          <div><i class='bx bx-time'></i> <%= task.dueDate ? new Date(task.dueDate).toLocaleDateString('es-CO') : 'Sin fecha' %></div>
          <div><i class='bx bx-flag'></i> <%= task.priority %></div>
          <div><i class='bx bx-check-circle'></i> <%= task.status %></div>
        </div>
        <% if (task.description) { %>
          <p style="font-size:13px; color:#64748b; margin:8px 0;"><%= task.description %></p>
        <% } %>
        <div class="task-actions">
          <% if (task.status !== 'completada') { %>
            <button class="btn-task btn-complete" onclick="completeTask('<%= task._id %>')">Completar</button>
          <% } %>
          <% if (task.status === 'pendiente') { %>
            <button class="btn-task btn-progress" onclick="startTask('<%= task._id %>')">Iniciar</button>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div style="text-align:center; padding:60px 20px; color:#64748b;">
      <i class='bx bx-task' style="font-size:48px; opacity:0.3;"></i>
      <p style="margin-top:16px;">No hay tareas registradas</p>
    </div>
  <% } %>
</div>

<!-- Modal Nueva Tarea -->
<div id="newTaskModal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:99999; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:16px; width:90%; max-width:600px; padding:24px; position:relative;">
    <button onclick="document.getElementById('newTaskModal').style.display='none'" style="position:absolute; top:16px; right:16px; background:#f0f2f4; border:none; width:32px; height:32px; border-radius:50%; cursor:pointer; font-size:18px;">×</button>
    <h3 style="margin:0 0 20px 0; font-size:20px; font-weight:700;">Nueva Tarea</h3>
    <form id="taskForm" onsubmit="createTask(event)">
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:600; margin-bottom:6px;">Título *</label>
        <input type="text" id="taskTitle" required style="width:100%; padding:10px; border:1px solid #d9dee3; border-radius:8px;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:600; margin-bottom:6px;">Descripción</label>
        <textarea id="taskDescription" rows="3" style="width:100%; padding:10px; border:1px solid #d9dee3; border-radius:8px;"></textarea>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
        <div>
          <label style="display:block; font-size:13px; font-weight:600; margin-bottom:6px;">Asignar a *</label>
          <select id="taskAssigned" required style="width:100%; padding:10px; border:1px solid #d9dee3; border-radius:8px;">
            <% users.forEach(u => { %>
              <option value="<%= u._id %>"><%= u.fullName || u.username %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label style="display:block; font-size:13px; font-weight:600; margin-bottom:6px;">Fecha límite</label>
          <input type="date" id="taskDueDate" style="width:100%; padding:10px; border:1px solid #d9dee3; border-radius:8px;">
        </div>
      </div>
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:600; margin-bottom:6px;">Prioridad</label>
        <select id="taskPriority" style="width:100%; padding:10px; border:1px solid #d9dee3; border-radius:8px;">
          <option value="baja">Baja</option>
          <option value="media" selected>Media</option>
          <option value="alta">Alta</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;">Crear Tarea</button>
    </form>
  </div>
</div>

<script>
function openNewTaskModal() {
  document.getElementById('newTaskModal').style.display = 'flex';
}

async function createTask(e) {
  e.preventDefault();
  const data = {
    title: document.getElementById('taskTitle').value,
    description: document.getElementById('taskDescription').value,
    assignedTo: document.getElementById('taskAssigned').value,
    dueDate: document.getElementById('taskDueDate').value || null,
    priority: document.getElementById('taskPriority').value
  };
  
  try {
    const res = await fetch('/api/tasks', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(data)
    });
    const result = await res.json();
    if (result.success) {
      location.reload();
    } else {
      alert('Error: ' + result.message);
    }
  } catch(err) {
    alert('Error: ' + err.message);
  }
}

async function completeTask(id) {
  if (!confirm('¿Marcar como completada?')) return;
  await updateTaskStatus(id, 'completada');
}

async function startTask(id) {
  await updateTaskStatus(id, 'en_proceso');
}

async function updateTaskStatus(id, status) {
  try {
    const res = await fetch('/api/tasks/' + id + '/status', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ status })
    });
    const result = await res.json();
    if (result.success) {
      location.reload();
    } else {
      alert('Error: ' + result.message);
    }
  } catch(err) {
    alert('Error: ' + err.message);
  }
}
</script>
