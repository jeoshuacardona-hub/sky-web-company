<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Tablero de Tareas (Task Board)</h5>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTaskModal">
          <i class="bx bx-plus"></i> Nueva Tarea
        </button>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4 mb-4">
            <h6 class="fw-bold mb-3 text-secondary">Pendientes</h6>
            <% tasks.filter(t => t.status === 'todo').forEach(task => { %>
              <div class="card mb-3 shadow-sm">
                <div class="card-body p-3">
                  <div class="d-flex justify-content-between align-items-start">
                    <h6 class="mb-1"><%= task.title %></h6>
                    <form action="/tasks/update" method="POST" class="d-inline">
                      <input type="hidden" name="id" value="<%= task._id %>">
                      <input type="hidden" name="status" value="in-progress">
                      <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bx bx-play"></i></button>
                    </form>
                  </div>
                  <p class="small text-muted mb-2"><%= task.description %></p>
                  <span class="badge bg-label-secondary"><%= task.priority %></span>
                </div>
              </div>
            <% }) %>
          </div>
          <div class="col-md-4 mb-4">
            <h6 class="fw-bold mb-3 text-primary">En Progreso</h6>
            <% tasks.filter(t => t.status === 'in-progress').forEach(task => { %>
              <div class="card mb-3 shadow-sm border-primary">
                <div class="card-body p-3">
                  <div class="d-flex justify-content-between align-items-start">
                    <h6 class="mb-1"><%= task.title %></h6>
                    <form action="/tasks/update" method="POST" class="d-inline">
                      <input type="hidden" name="id" value="<%= task._id %>">
                      <input type="hidden" name="status" value="done">
                      <button type="submit" class="btn btn-sm btn-outline-success"><i class="bx bx-check"></i></button>
                    </form>
                  </div>
                  <p class="small text-muted mb-2"><%= task.description %></p>
                  <span class="badge bg-label-primary"><%= task.priority %></span>
                </div>
              </div>
            <% }) %>
          </div>
          <div class="col-md-4 mb-4">
            <h6 class="fw-bold mb-3 text-success">Completadas</h6>
            <% tasks.filter(t => t.status === 'done').forEach(task => { %>
              <div class="card mb-3 shadow-sm bg-light">
                <div class="card-body p-3 text-muted">
                  <div class="d-flex justify-content-between align-items-start">
                    <h6 class="mb-1 text-decoration-line-through"><%= task.title %></h6>
                    <form action="/tasks/update" method="POST" class="d-inline">
                      <input type="hidden" name="id" value="<%= task._id %>">
                      <input type="hidden" name="status" value="todo">
                      <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bx bx-undo"></i></button>
                    </form>
                  </div>
                  <p class="small mb-2"><%= task.description %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Agregar Tarea -->
<div class="modal fade" id="addTaskModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Nueva Tarea</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/tasks/add" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Título</label>
            <input type="text" name="title" class="form-control" required />
          </div>
          <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea name="description" class="form-control" rows="3"></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Prioridad</label>
            <select name="priority" class="form-select">
              <option value="low">Baja</option>
              <option value="medium" selected>Media</option>
              <option value="high">Alta</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Crear Tarea</button>
        </div>
      </form>
    </div>
  </div>
</div>
