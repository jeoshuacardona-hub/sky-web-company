<style>
.lead-call-card { background:#fff; border-radius:10px; border:1px solid #f0f0f0; padding:16px; margin-bottom:10px; transition:box-shadow 0.15s; }
.lead-call-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.07); }
.avatar-sm { width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; flex-shrink:0; }
.status-new { background:#e8eaff; color:#4a50d4; font-size:11px; font-weight:600; padding:2px 10px; border-radius:20px; }
.status-contacted { background:#fff0d6; color:#b36800; font-size:11px; font-weight:600; padding:2px 10px; border-radius:20px; }
.outcome-option { border:2px solid #f0f0f0; border-radius:12px; padding:16px 8px; cursor:pointer; transition:all 0.15s; text-align:center; height:100%; }
.outcome-option:hover { border-color:#bbb; }
.outcome-option.selected-scheduled { border-color:#71dd37!important; background:#f0faeb!important; }
.outcome-option.selected-callback { border-color:#ffab00!important; background:#fff8e6!important; }
.outcome-option.selected-rejected { border-color:#ff3e1d!important; background:#fff0ee!important; }
.outcome-option.selected-no_answer { border-color:#8a8d9f!important; background:#f5f5f5!important; }
.stat-sm { background:#fff; border-radius:12px; padding:14px 18px; border:1px solid #f0f0f0; display:flex; align-items:center; gap:12px; }
</style>

<%
var colorMap = ['#696cff','#03c3ec','#71dd37','#ff3e1d','#ffab00','#20c997'];
function getInitials(name){ if(!name)return'?'; return name.split(' ').map(function(w){return w[0];}).join('').toUpperCase().slice(0,2); }
function getColor(str){ var h=0; for(var i=0;i<(str||'').length;i++) h=str.charCodeAt(i)+((h<<5)-h); return colorMap[Math.abs(h)%colorMap.length]; }
%>

<div class="d-flex flex-wrap gap-3 mb-4">
  <div class="stat-sm">
    <div style="width:38px;height:38px;border-radius:10px;background:#696cff22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-target-lock" style="font-size:20px;color:#696cff;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Sin Llamar</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;"><%= totalNew %></p>
    </div>
  </div>
  <div class="stat-sm">
    <div style="width:38px;height:38px;border-radius:10px;background:#03c3ec22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-phone" style="font-size:20px;color:#03c3ec;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Llamadas Hoy</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#03c3ec;"><%= callsToday %></p>
    </div>
  </div>
  <div class="stat-sm">
    <div style="width:38px;height:38px;border-radius:10px;background:#71dd3722;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-calendar-check" style="font-size:20px;color:#71dd37;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Agendados Hoy</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#71dd37;"><%= scheduledToday %></p>
    </div>
  </div>
  <div class="stat-sm">
    <div style="width:38px;height:38px;border-radius:10px;background:#ffab0022;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-list-ul" style="font-size:20px;color:#ffab00;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">En Lista</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#ffab00;"><%= leads.length %></p>
    </div>
  </div>
</div>

<div class="card" style="border-radius:12px;border:1px solid #f0f0f0;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
  <div class="card-header d-flex align-items-center justify-content-between py-3 px-4" style="background:#fff;border-bottom:1px solid #f0f0f0;border-radius:12px 12px 0 0;">
    <div>
      <h6 class="mb-0" style="font-weight:700;">Lista de Llamadas</h6>
      <p class="mb-0" style="font-size:12px;color:#8a8d9f;">Leads pendientes de contactar</p>
    </div>
    <a href="/leads" class="btn btn-sm btn-outline-secondary">Ver todos los leads</a>
  </div>

  <% if (leads.length === 0) { %>
    <div style="text-align:center;padding:56px 0;">
      <i class="bx bx-check-circle" style="font-size:48px;color:#71dd37;display:block;margin-bottom:12px;"></i>
      <p style="font-weight:600;color:#5d596c;margin-bottom:4px;">Lista al dia</p>
      <p style="font-size:13px;color:#c5c7d4;margin:0;">No hay leads pendientes de llamar</p>
    </div>
  <% } %>

  <div class="px-4 py-3">
    <% leads.forEach(function(lead) {
      var initials = getInitials(lead.name);
      var color = getColor(lead.name);
      var lastCall = callMap[lead._id.toString()];
    %>
    <div class="lead-call-card" id="lead-card-<%= lead._id %>">
      <div class="d-flex align-items-center gap-3">
        <div class="avatar-sm" style="background:<%= color %>22;color:<%= color %>;"><%= initials %></div>
        <div style="flex:1;min-width:0;">
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <p class="mb-0" style="font-size:14px;font-weight:700;"><%= lead.name %></p>
            <span class="<%= lead.status === 'new' ? 'status-new' : 'status-contacted' %>">
              <%= lead.status === 'new' ? 'Sin llamar' : 'Contactado' %>
            </span>
            <% if (lastCall) { %>
              <span style="font-size:11px;color:#c5c7d4;">Ultimo: <%= new Date(lastCall.createdAt).toLocaleDateString('es-CO', {day:'2-digit',month:'short'}) %></span>
            <% } %>
          </div>
          <div class="d-flex gap-3 mt-1 flex-wrap">
            <% if (lead.company) { %><span style="font-size:12px;color:#8a8d9f;"><i class="bx bx-buildings" style="font-size:12px;"></i> <%= lead.company %></span><% } %>
            <% if (lead.phone) { %><span style="font-size:12px;color:#5d596c;font-weight:500;"><i class="bx bx-phone" style="font-size:12px;"></i> <%= lead.phone %></span><% } %>
            <% if (lead.email) { %><span style="font-size:12px;color:#8a8d9f;"><i class="bx bx-envelope" style="font-size:12px;"></i> <%= lead.email %></span><% } %>
          </div>
        </div>
        <button class="btn btn-primary btn-sm flex-shrink-0"
          data-id="<%= lead._id %>"
          data-name="<%= lead.name %>"
          data-phone="<%= lead.phone || '' %>"
          data-company="<%= lead.company || '' %>"
          onclick="abrirModal(this)">
          <i class="bx bx-phone me-1"></i> Llamar
        </button>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Modal -->
<div class="modal fade" id="callModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 8px 40px rgba(0,0,0,0.12);">
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <div>
          <h5 class="modal-title mb-0" style="font-weight:700;">Registrar Llamada</h5>
          <p class="text-muted mb-0" style="font-size:13px;" id="callModalInfo"></p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4 pt-3">
        <input type="hidden" id="callLeadId">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#8a8d9f;margin-bottom:10px;">Resultado de la llamada</p>
        <div class="row g-2 mb-3">
          <div class="col-6">
            <div class="outcome-option" onclick="selectOutcome(this,'scheduled')">
              <i class="bx bx-calendar-check" style="font-size:26px;color:#71dd37;display:block;margin-bottom:6px;"></i>
              <p style="font-size:11px;font-weight:700;margin:0;color:#71dd37;">Agendo Reunion</p>
            </div>
          </div>
          <div class="col-6">
            <div class="outcome-option" onclick="selectOutcome(this,'callback')">
              <i class="bx bx-time" style="font-size:26px;color:#ffab00;display:block;margin-bottom:6px;"></i>
              <p style="font-size:11px;font-weight:700;margin:0;color:#ffab00;">Volver a Llamar</p>
            </div>
          </div>
          <div class="col-6">
            <div class="outcome-option" onclick="selectOutcome(this,'rejected')">
              <i class="bx bx-x-circle" style="font-size:26px;color:#ff3e1d;display:block;margin-bottom:6px;"></i>
              <p style="font-size:11px;font-weight:700;margin:0;color:#ff3e1d;">No Interesado</p>
            </div>
          </div>
          <div class="col-6">
            <div class="outcome-option" onclick="selectOutcome(this,'no_answer')">
              <i class="bx bx-phone-off" style="font-size:26px;color:#8a8d9f;display:block;margin-bottom:6px;"></i>
              <p style="font-size:11px;font-weight:700;margin:0;color:#8a8d9f;">No Contesto</p>
            </div>
          </div>
        </div>
        <div id="extraScheduled" style="display:none;" class="mb-3">
          <label class="form-label fw-semibold" style="font-size:13px;">Valor estimado del proyecto ($)</label>
          <input type="number" id="callValue" class="form-control" placeholder="2000000">
        </div>
        <div id="extraCallback" style="display:none;" class="mb-3">
          <label class="form-label fw-semibold" style="font-size:13px;">Fecha para rellamar</label>
          <input type="date" id="callCallbackDate" class="form-control">
        </div>
        <div id="extraRejected" style="display:none;" class="mb-3">
          <label class="form-label fw-semibold" style="font-size:13px;">Motivo del rechazo</label>
          <select id="callRejectionReason" class="form-select">
            <option value="">Seleccionar...</option>
            <option>No tiene presupuesto</option>
            <option>Ya tiene proveedor</option>
            <option>No es el momento</option>
            <option>No le interesa el servicio</option>
            <option>No contesta repetidamente</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="mb-2">
          <label class="form-label fw-semibold" style="font-size:13px;">Notas de la llamada</label>
          <textarea id="callNotes" class="form-control" rows="2" placeholder="Comentarios..."></textarea>
        </div>
        <div id="callResult" style="display:none;"></div>
      </div>
      <div class="modal-footer border-0 px-4 pb-4 pt-2">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button id="submitCallBtn" class="btn btn-primary px-4" onclick="submitLlamada()" disabled>
          <i class="bx bx-check me-1"></i> Guardar
        </button>
      </div>
    </div>
  </div>
</div>

<script>
var selectedOutcome = null;

function abrirModal(btn) {
  selectedOutcome = null;
  document.getElementById('callLeadId').value = btn.dataset.id;
  document.getElementById('callModalInfo').textContent = btn.dataset.name + (btn.dataset.phone ? ' - ' + btn.dataset.phone : '') + (btn.dataset.company ? ' | ' + btn.dataset.company : '');
  document.getElementById('callNotes').value = '';
  document.getElementById('callValue').value = '';
  document.getElementById('callCallbackDate').value = '';
  document.getElementById('callRejectionReason').value = '';
  document.getElementById('callResult').style.display = 'none';
  document.getElementById('submitCallBtn').disabled = true;
  document.querySelectorAll('.outcome-option').forEach(function(el){ el.className = 'outcome-option'; });
  ['extraScheduled','extraCallback','extraRejected'].forEach(function(id){ document.getElementById(id).style.display='none'; });
  new bootstrap.Modal(document.getElementById('callModal')).show();
}

function selectOutcome(el, outcome) {
  selectedOutcome = outcome;
  document.querySelectorAll('.outcome-option').forEach(function(o){ o.className = 'outcome-option'; });
  el.className = 'outcome-option selected-' + outcome;
  document.getElementById('extraScheduled').style.display = outcome === 'scheduled' ? 'block' : 'none';
  document.getElementById('extraCallback').style.display = outcome === 'callback' ? 'block' : 'none';
  document.getElementById('extraRejected').style.display = outcome === 'rejected' ? 'block' : 'none';
  document.getElementById('submitCallBtn').disabled = false;
}

async function submitLlamada() {
  if (!selectedOutcome) return;
  var btn = document.getElementById('submitCallBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Guardando...';
  try {
    var res = await fetch('/api/llamadas', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        leadId: document.getElementById('callLeadId').value,
        outcome: selectedOutcome,
        notes: document.getElementById('callNotes').value,
        value: document.getElementById('callValue').value,
        callbackDate: document.getElementById('callCallbackDate').value,
        rejectionReason: document.getElementById('callRejectionReason').value
      })
    });
    var data = await res.json();
    var el = document.getElementById('callResult');
    if (data.success) {
      var msgs = { scheduled:'Reunion agendada. El lead paso a Pipeline.', callback:'Programado para seguimiento.', rejected:'Lead marcado como no interesado.', no_answer:'Llamada registrada. El lead permanece en la lista.' };
      el.innerHTML = '<div style="background:#e2f8ef;border-radius:10px;padding:12px;font-size:13px;font-weight:600;color:#1a7a50;margin-top:8px;"><i class="bx bx-check-circle me-1"></i>' + (msgs[data.outcome] || 'Guardado.') + '</div>';
      el.style.display = 'block';
      setTimeout(function(){ location.reload(); }, 1800);
    } else {
      el.innerHTML = '<div style="background:#fde8e8;border-radius:10px;padding:12px;font-size:13px;color:#b32020;margin-top:8px;">' + (data.message || 'Error al guardar') + '</div>';
      el.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<i class="bx bx-check me-1"></i> Guardar';
    }
  } catch(e) {
    alert('Error de conexion.');
    btn.disabled = false;
    btn.innerHTML = '<i class="bx bx-check me-1"></i> Guardar';
  }
}
</script>
