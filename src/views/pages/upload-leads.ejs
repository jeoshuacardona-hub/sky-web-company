<style>
.upload-card { background:#fff; border-radius:12px; padding:32px; border:1px solid #f0f2f4; max-width:600px; margin:0 auto; }
.form-label { font-weight:600; color:#566a7f; margin-bottom:8px; display:block; }
.form-control, .form-select { border-radius:8px; border:1px solid #d9dee3; padding:10px 12px; }
.btn-upload { background:#696cff; color:#fff; border:none; padding:12px 32px; border-radius:8px; font-weight:600; cursor:pointer; width:100%; margin-top:20px; }
.btn-upload:hover { background:#5a58ea; }
.provider-badge { display:inline-block; padding:4px 12px; border-radius:20px; font-size:11px; font-weight:600; margin-left:8px; }
.provider-angel { background:rgba(105,108,255,0.15); color:#696cff; }
.provider-danilo { background:rgba(113,221,55,0.15); color:#71dd37; }
.provider-julian { background:rgba(3,195,236,0.15); color:#03c3ec; }
.provider-otro { background:rgba(138,141,159,0.15); color:#8a8d9f; }
</style>

<div class="container py-5">
  <div class="upload-card">
    <h2 style="font-size:24px; font-weight:700; color:#566a7f; margin-bottom:8px;">
      <i class='bx bx-upload me-2'></i>Subir Leads CSV
    </h2>
    <p style="color:#697a8d; margin-bottom:24px;">Selecciona el archivo y quién te lo proporcionó</p>
    
    <form action="/leads/upload" method="POST" enctype="multipart/form-data">
      <div class="mb-4">
        <label class="form-label">Proveedor del Lead *</label>
        <select name="providedBy" class="form-select" required>
          <option value="">Seleccionar...</option>
          <option value="Angel Mateo">Angel Mateo</option>
          <option value="Danilo">Danilo</option>
          <option value="Julian">Julian</option>
          <option value="Otro">Otro</option>
        </select>
        <small style="color:#697a8d; font-size:11px;">¿Quién te pasó estos leads?</small>
      </div>
      
      <div class="mb-4">
        <label class="form-label">Archivo CSV *</label>
        <input type="file" name="file" class="form-control" accept=".csv" required>
        <small style="color:#697a8d; font-size:11px;">Formato: Nombre, Teléfono, Email, Empresa, Ciudad</small>
      </div>
      
      <button type="submit" class="btn-upload">
        <i class='bx bx-cloud-upload me-2'></i>Subir Leads
      </button>
      <a href="/leads" class="btn btn-outline-secondary w-100 mt-2" style="border-radius:8px;">
        <i class='bx bx-arrow-back me-2'></i>Volver a Leads
      </a>
    </form>
  </div>
</div>
