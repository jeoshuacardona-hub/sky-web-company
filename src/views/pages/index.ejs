<div class="row">
  <div class="col-xxl-8 mb-6 order-0">
    <div class="card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">¡Bienvenido a Sky Web Company! 🎉</h5>
            <p class="mb-6">
              Estás en el centro de mando de tu empresa. Desde aquí puedes gestionar todo el flujo de trabajo,
              monitorear el crecimiento y optimizar tus servicios web.
            </p>
            <a href="/customers" class="btn btn-sm btn-outline-primary">Ver Clientes</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="/assets/img/illustrations/man-with-laptop.png" height="175" alt="Sky Web Company" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xxl-4 col-lg-12 col-md-4 order-1">
    <div class="row">
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <p class="mb-1">Clientes</p>
            <h4 class="card-title mb-3"><%= stats.customers %></h4>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <p class="mb-1">Tareas Pendientes</p>
            <h4 class="card-title mb-3"><%= stats.tasks %></h4>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <p class="mb-1">Negocios Cerrados</p>
            <h4 class="card-title mb-3"><%= stats.revenue %></h4>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
