<div class="row g-4 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <span class="fw-medium d-block mb-1">Clientes</span>
            <h3 class="card-title mb-2"><%= stats.customers %></h3>
            <a href="/customers" class="btn btn-sm btn-outline-primary">Ver todos</a>
          </div>
          <div class="avatar flex-shrink-0">
            <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-user icon-lg"></i></span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <span class="fw-medium d-block mb-1">Leads</span>
            <h3 class="card-title mb-2"><%= stats.leads %></h3>
            <a href="/leads" class="btn btn-sm btn-outline-warning">Ver todos</a>
          </div>
          <div class="avatar flex-shrink-0">
            <span class="avatar-initial rounded bg-label-warning"><i class="icon-base bx bx-target-lock icon-lg"></i></span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <span class="fw-medium d-block mb-1">Tareas Pendientes</span>
            <h3 class="card-title mb-2"><%= stats.tasks %></h3>
            <a href="/tasks" class="btn btn-sm btn-outline-danger">Ver todas</a>
          </div>
          <div class="avatar flex-shrink-0">
            <span class="avatar-initial rounded bg-label-danger"><i class="icon-base bx bx-task icon-lg"></i></span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <span class="fw-medium d-block mb-1">Negocios Cerrados</span>
            <h3 class="card-title mb-2"><%= stats.revenue %></h3>
            <a href="/customers" class="btn btn-sm btn-outline-success">Ver todos</a>
          </div>
          <div class="avatar flex-shrink-0">
            <span class="avatar-initial rounded bg-label-success"><i class="icon-base bx bx-check-circle icon-lg"></i></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="row g-4">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Últimos Leads</h5>
        <a href="/leads" class="btn btn-sm btn-primary">Ver todos</a>
      </div>
      <div class="card-body">
        <% if (stats.recentLeads && stats.recentLeads.length > 0) { %>
          <ul class="list-group list-group-flush">
            <% stats.recentLeads.forEach(lead => { %>
              <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                <div>
                  <strong><%= lead.name %></strong>
                  <small class="d-block text-muted"><%= lead.company || 'Sin empresa' %></small>
                </div>
                <span class="badge bg-label-<%= lead.status === 'new' ? 'info' : lead.status === 'converted' ? 'success' : 'warning' %>"><%= lead.status %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="text-muted text-center mt-3">No hay leads aún. <a href="/leads">Agregar primero</a></p>
        <% } %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Tareas Pendientes</h5>
        <a href="/tasks" class="btn btn-sm btn-primary">Ver todas</a>
      </div>
      <div class="card-body">
        <% if (stats.recentTasks && stats.recentTasks.length > 0) { %>
          <ul class="list-group list-group-flush">
            <% stats.recentTasks.forEach(task => { %>
              <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                <div>
                  <strong><%= task.title %></strong>
                  <small class="d-block text-muted"><%= task.description ? task.description.substring(0,40) + '...' : '' %></small>
                </div>
                <span class="badge bg-label-<%= task.priority === 'high' ? 'danger' : task.priority === 'medium' ? 'warning' : 'info' %>"><%= task.priority %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="text-muted text-center mt-3">No hay tareas pendientes.</p>
        <% } %>
      </div>
    </div>
  </div>
</div>
