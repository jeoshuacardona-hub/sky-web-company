<link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

<style>
.pipeline-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 24px 32px; color: #fff; margin-bottom: 24px; }
.pipeline-header h1 { margin: 0 0 8px 0; font-size: 26px; font-weight: 700; }
.pipeline-header p { margin: 0; opacity: 0.9; font-size: 15px; }
.pipeline-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-bottom: 24px; }
.stat-box { background: #fff; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); border: 1px solid #f0f2f4; }
.stat-box h3 { font-size: 28px; font-weight: 700; color: #667eea; margin: 0 0 4px 0; }
.stat-box p { font-size: 13px; color: #697a8d; margin: 0; font-weight: 500; }
.btn-new { background: #667eea; color: #fff; border: none; padding: 12px 24px; border-radius: 10px; font-weight: 600; font-size: 14px; cursor: pointer; margin-bottom: 24px; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
.btn-new:hover { background: #5a67d8; transform: translateY(-2px); }
.pipeline-board { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; }
.pipeline-column { background: #f8f9fa; border-radius: 12px; padding: 16px; min-height: 400px; }
.column-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 2px solid #e2e8f0; }
.column-header h3 { font-size: 14px; font-weight: 700; color: #566a7f; margin: 0; text-transform: uppercase; letter-spacing: 0.5px; }
.column-count { background: #667eea; color: #fff; padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; }
.customer-card { background: #fff; border-radius: 10px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.04); border-left: 4px solid #667eea; transition: all 0.2s; position: relative; }
.customer-card:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,0.08); }
.customer-card.qualified { border-left-color: #71dd37; }
.customer-card.proposal { border-left-color: #ffab00; }
.customer-card.negotiation { border-left-color: #8b5cf6; }
.customer-card.closed_won { border-left-color: #34c759; opacity: 0.85; }
.customer-card.closed_lost { border-left-color: #ff3b30; opacity: 0.7; }
.customer-name { font-weight: 600; color: #566a7f; font-size: 15px; margin-bottom: 8px; }
.customer-value { font-size: 18px; font-weight: 700; color: #667eea; margin-bottom: 8px; }
.customer-meta { font-size: 12px; color: #697a8d; margin: 4px 0; display: flex; align-items: center; gap: 6px; }
.customer-actions { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
.btn-sm { padding: 6px 12px; border-radius: 6px; border: none; font-size: 11px; font-weight: 600; cursor: pointer; transition: 0.2s; }
.btn-qualify { background: rgba(113,221,55,0.15); color: #71dd37; }
.btn-proposal { background: rgba(255,171,0,0.15); color: #ffab00; }
.btn-negotiate { background: rgba(139,92,246,0.15); color: #8b5cf6; }
.btn-won { background: rgba(52,199,89,0.15); color: #34c759; }
.btn-lost { background: rgba(255,59,48,0.15); color: #ff3b30; }
.btn-sm:hover { transform: scale(1.05); }
.btn-delete { position: absolute; top: 12px; right: 12px; background: #fee2e2; color: #dc2626; border: none; width: 28px; height: 28px; border-radius: 6px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
.btn-delete:hover { background: #fecaca; transform: scale(1.1); }
.empty-state { text-align: center; padding: 40px 20px; color: #697a8d; }
.empty-state i { font-size: 48px; opacity: 0.3; margin-bottom: 12px; display: block; }
.toast { position: fixed; bottom: 20px; right: 20px; padding: 12px 20px; border-radius: 8px; color: #fff; font-weight: 600; z-index: 999999; opacity: 0; transition: opacity 0.3s; }
.toast.show { opacity: 1; }
.toast.success { background: #16a34a; }
.toast.error { background: #dc2626; }
</style>

<div class="pipeline-header">
  <h1>🚀 Pipeline de Ventas</h1>
  <p>Gestiona tus oportunidades de negocio</p>
</div>

<div class="pipeline-stats">
  <div class="stat-box"><h3><%= stats.total || 0 %></h3><p>Total</p></div>
  <div class="stat-box"><h3><%= stats.valorPipeline ? '$' + (stats.valorPipeline/1000000).toFixed(1) + 'M' : '$0' %></h3><p>Valor Pipeline</p></div>
  <div class="stat-box"><h3><%= stats.ganados || 0 %></h3><p>Ganados</p></div>
  <div class="stat-box"><h3><%= stats.perdidos || 0 %></h3><p>Perdidos</p></div>
</div>

<% if (isAdmin) { %>
<button class="btn-new" id="btnNuevoCliente"><i class='bx bx-plus'></i> Nuevo Cliente</button>
<% } %>

<div class="pipeline-board">
  <% const statuses = [
    { key: 'prospect', label: '📋 PROSPECTOS', class: '' },
    { key: 'qualified', label: '✅ CALIFICADOS', class: 'qualified' },
    { key: 'proposal', label: '📄 PROPUESTA', class: 'proposal' },
    { key: 'negotiation', label: '💬 NEGOCIACIÓN', class: 'negotiation' },
    { key: 'closed_won', label: '✓ GANADOS', class: 'closed_won' },
    { key: 'closed_lost', label: '× PERDIDOS', class: 'closed_lost' }
  ]; %>
  
  <% statuses.forEach(status => { %>
    <div class="pipeline-column">
      <div class="column-header">
        <h3><%= status.label %></h3>
        <span class="column-count"><%= customers.filter(c=>c.status===status.key).length %></span>
      </div>
      <% const items = customers.filter(c=>c.status===status.key); %>
      <% if (items.length === 0) { %>
        <div class="empty-state"><i class='bx bx-user'></i>Sin <%= status.key === 'prospect' ? 'prospectos' : status.key === 'qualified' ? 'calificados' : status.key === 'proposal' ? 'propuestas' : status.key === 'negotiation' ? 'negociaciones' : status.key === 'closed_won' ? 'ganados' : 'perdidos' %></div>
      <% } else { %>
        <% items.forEach(c => { %>
          <div class="customer-card <%= status.class %>" data-id="<%= c._id %>">
            <% if (isAdmin) { %>
            <button class="btn-delete" onclick="deleteCustomer('<%= c._id %>')" title="Eliminar"><i class='bx bx-trash'></i></button>
            <% } %>
            <div class="customer-name"><%= c.name %></div>
            <% if (c.value) { %><div class="customer-value"><%= c.value.toLocaleString('es-CO', {style:'currency', currency:'COP', maximumFractionDigits:0}) %></div><% } %>
            <% if (c.phone) { %><div class="customer-meta"><i class='bx bx-phone'></i> <%= c.phone %></div><% } %>
            <% if (c.company) { %><div class="customer-meta"><i class='bx bx-buildings'></i> <%= c.company %></div><% } %>
            <% if (c.notes) { %><div class="customer-meta" style="font-style:italic;"><i class='bx bx-comment-detail'></i> <%= c.notes.length > 60 ? c.notes.substring(0,60) + '...' : c.notes %></div><% } %>
            <% if (c.assignedTo) { %>
              <div class="customer-meta" style="color:#696cff; font-weight: 600; margin-top: 4px;"><i class='bx bx-user'></i> <%= c.assignedTo.fullName || c.assignedTo.username %></div>
            <% } %>
            <% if (isAdmin) { %>
            <div class="customer-actions">
              <% if (status.key === 'prospect') { %>
                <button class="btn-sm btn-qualify" onclick="changeStatus('<%= c._id %>', 'qualified')">✓ Calificar</button>
                <button class="btn-sm btn-proposal" onclick="changeStatus('<%= c._id %>', 'proposal')">📄 Propuesta</button>
                <button class="btn-sm btn-lost" onclick="changeStatus('<%= c._id %>', 'closed_lost')">✕</button>
              <% } else if (status.key === 'qualified') { %>
                <button class="btn-sm btn-proposal" onclick="changeStatus('<%= c._id %>', 'proposal')">📄 Propuesta</button>
                <button class="btn-sm btn-lost" onclick="changeStatus('<%= c._id %>', 'closed_lost')">✕</button>
              <% } else if (status.key === 'proposal') { %>
                <button class="btn-sm btn-negotiate" onclick="changeStatus('<%= c._id %>', 'negotiation')">💬 Negociar</button>
                <button class="btn-sm btn-won" onclick="changeStatus('<%= c._id %>', 'closed_won')">✓</button>
                <button class="btn-sm btn-lost" onclick="changeStatus('<%= c._id %>', 'closed_lost')">✕</button>
              <% } else if (status.key === 'negotiation') { %>
                <button class="btn-sm btn-won" onclick="changeStatus('<%= c._id %>', 'closed_won')">✓ Ganado</button>
                <button class="btn-sm btn-lost" onclick="changeStatus('<%= c._id %>', 'closed_lost')">✕ Perdido</button>
              <% } %>
            </div>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </div>
  <% }) %>
</div>

<!-- Modal Nuevo Cliente -->
<div id="modalOverlay" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:99999; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:16px; width:90%; max-width:500px; padding:24px; position:relative;">
    <button onclick="document.getElementById('modalOverlay').style.display='none'" style="position:absolute; top:16px; right:16px; background:#f0f2f4; border:none; width:32px; height:32px; border-radius:50%; cursor:pointer; font-size:18px; display:flex; align-items:center; justify-content:center; color:#697a8d;">×</button>
    <h3 style="margin:0 0 20px 0; font-size:20px; color:#566a7f; font-weight:700;">✨ Nuevo Cliente</h3>
    <form id="customerForm" onsubmit="saveCustomer(event)">
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:500; color:#566a7f; margin-bottom:6px;">Nombre del Cliente *</label>
        <input type="text" id="custName" required placeholder="Ej: Empresa XYZ" style="width:100%; padding:10px 12px; border:1px solid #d9dee3; border-radius:8px; font-size:14px;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:500; color:#566a7f; margin-bottom:6px;">Teléfono</label>
        <input type="tel" id="custPhone" placeholder="+57 300 123 4567" style="width:100%; padding:10px 12px; border:1px solid #d9dee3; border-radius:8px; font-size:14px;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:500; color:#566a7f; margin-bottom:6px;">Empresa</label>
        <input type="text" id="custCompany" placeholder="Nombre de la empresa" style="width:100%; padding:10px 12px; border:1px solid #d9dee3; border-radius:8px; font-size:14px;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:500; color:#566a7f; margin-bottom:6px;">Valor Estimado (COP)</label>
        <input type="number" id="custValue" placeholder="0" min="0" style="width:100%; padding:10px 12px; border:1px solid #d9dee3; border-radius:8px; font-size:14px;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:500; color:#566a7f; margin-bottom:6px;">Estado Inicial</label>
        <select id="custStatus" style="width:100%; padding:10px 12px; border:1px solid #d9dee3; border-radius:8px; font-size:14px;">
          <option value="prospect">📋 Prospecto</option>
          <option value="qualified">✅ Calificado</option>
          <option value="proposal">📄 Propuesta</option>
          <option value="negotiation">💬 Negociación</option>
        </select>
      </div>
      <div style="margin-bottom:16px;">
        <label style="display:block; font-size:13px; font-weight:500; color:#566a7f; margin-bottom:6px;">Notas</label>
        <textarea id="custNotes" rows="3" placeholder="Detalles adicionales..." maxlength="500" style="width:100%; padding:10px 12px; border:1px solid #d9dee3; border-radius:8px; font-size:14px;"></textarea>
      </div>
      <button type="submit" id="btnSaveCustomer" style="width:100%; padding:12px; background:#667eea; color:#fff; border:none; border-radius:8px; font-weight:600; cursor:pointer;">💾 Guardar Cliente</button>
    </form>
  </div>
</div>

<!-- Toast para notificaciones -->
<div id="toast" class="toast"></div>

<script>
// ============ UTILIDADES ============
function showToast(message, type) {
  var toast = document.getElementById('toast');
  toast.textContent = message;
  toast.className = 'toast show ' + (type || 'success');
  setTimeout(function() { toast.className = 'toast'; }, 3000);
}

function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ============ MODAL NUEVO CLIENTE ============
document.getElementById('btnNuevoCliente').addEventListener('click', function() {
  document.getElementById('modalOverlay').style.display = 'flex';
  document.getElementById('customerForm').reset();
  setTimeout(function() { document.getElementById('custName').focus(); }, 100);
});

document.getElementById('modalOverlay').addEventListener('click', function(e) {
  if (e.target === this) this.style.display = 'none';
});

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.getElementById('modalOverlay').style.display = 'none';
  }
});

// ============ GUARDAR CLIENTE ============
async function saveCustomer(e) {
  e.preventDefault();
  var btn = document.getElementById('btnSaveCustomer');
  var originalText = btn.textContent;
  btn.disabled = true;
  btn.textContent = 'Guardando...';
  
  var name = document.getElementById('custName').value.trim();
  if (!name) {
    showToast('El nombre es obligatorio', 'error');
    btn.disabled = false;
    btn.textContent = originalText;
    return;
  }
  
  var data = {
    name: name,
    phone: document.getElementById('custPhone').value.trim(),
    company: document.getElementById('custCompany').value.trim(),
    value: parseInt(document.getElementById('custValue').value) || 0,
    status: document.getElementById('custStatus').value,
    notes: document.getElementById('custNotes').value.trim()
  };
  
  try {
    var res = await fetch('/api/customers', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(data)
    });
    
    if (!res.ok) {
      var errData = await res.json().catch(function() { return {error: 'Error HTTP ' + res.status}; });
      throw new Error(errData.error || errData.message || 'Error del servidor');
    }
    
    var result = await res.json();
    if (result.success) {
      showToast('✅ Cliente creado exitosamente', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else {
      throw new Error(result.error || result.message || 'Error al guardar');
    }
  } catch(err) {
    console.error('saveCustomer error:', err);
    showToast('❌ Error: ' + err.message, 'error');
    btn.disabled = false;
    btn.textContent = originalText;
  }
}

// ============ CAMBIAR ESTADO ============
async function changeStatus(id, newStatus) {
  var statusLabels = {
    prospect: 'Prospecto',
    qualified: 'Calificado',
    proposal: 'Propuesta',
    negotiation: 'Negociación',
    closed_won: 'Ganado',
    closed_lost: 'Perdido'
  };
  
  if (!confirm('¿Mover a "' + (statusLabels[newStatus] || newStatus) + '"?')) return;
  
  try {
    var res = await fetch('/api/pipeline/' + id + '/status', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ status: newStatus })
    });
    
    if (!res.ok) {
      var errData = await res.json().catch(function() { return {message: 'Error HTTP ' + res.status}; });
      throw new Error(errData.message || 'Error al cambiar estado');
    }
    
    var result = await res.json();
    if (result.success) {
      showToast('✅ Estado actualizado', 'success');
      setTimeout(function() { location.reload(); }, 600);
    } else {
      throw new Error(result.message || 'Error al cambiar estado');
    }
  } catch(err) {
    console.error('changeStatus error:', err);
    showToast('❌ Error: ' + err.message, 'error');
  }
}

// ============ ELIMINAR CLIENTE ============
async function deleteCustomer(id) {
  if (!confirm('¿Eliminar este cliente permanentemente?\n\nEsta acción no se puede deshacer.')) return;
  
  try {
    var res = await fetch('/api/pipeline/' + id + '/delete', {
      method: 'POST'
    });
    
    if (!res.ok) {
      var errData = await res.json().catch(function() { return {message: 'Error HTTP ' + res.status}; });
      throw new Error(errData.message || 'Error al eliminar');
    }
    
    var result = await res.json();
    if (result.success) {
      showToast('✅ Cliente eliminado', 'success');
      setTimeout(function() { location.reload(); }, 600);
    } else {
      throw new Error(result.message || 'Error al eliminar');
    }
  } catch(err) {
    console.error('deleteCustomer error:', err);
    showToast('❌ Error: ' + err.message, 'error');
  }
}
</script>
