<!-- Forzar carga de iconos -->
<link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

<style>
.pipeline-header { background: linear-gradient(135deg, #696cff 0%, #8b9aff 100%); border-radius: 16px; padding: 24px; color: #fff; margin-bottom: 24px; }
.pipeline-header h1 { margin: 0; font-size: 24px; font-weight: 700; }
.pipeline-header p { margin: 8px 0 0 0; opacity: 0.9; }

/* Stats */
.pipeline-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 24px; }
.stat-box { background: #fff; border-radius: 12px; padding: 16px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); border: 1px solid #f0f2f4; }
.stat-box h3 { font-size: 24px; font-weight: 700; color: #696cff; margin: 0 0 4px 0; }
.stat-box p { font-size: 12px; color: #697a8d; margin: 0; font-weight: 500; }

/* Pipeline Columns */
.pipeline-board { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; overflow-x: auto; padding-bottom: 16px; }
.pipeline-column { background: #f9fafb; border-radius: 12px; padding: 16px; min-height: 400px; }
.column-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 2px solid #e0e4e8; }
.column-header h3 { font-size: 14px; font-weight: 700; color: #566a7f; margin: 0; text-transform: uppercase; letter-spacing: 0.5px; }
.column-count { background: #696cff; color: #fff; padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; }

/* Customer Cards */
.customer-card { background: #fff; border-radius: 10px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.04); border-left: 4px solid #696cff; cursor: pointer; transition: all 0.2s; }
.customer-card:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,0.08); }
.customer-card.qualified { border-left-color: #71dd37; }
.customer-card.proposal { border-left-color: #ffab00; }
.customer-card.negotiation { border-left-color: #8b5cf6; }
.customer-card.won { border-left-color: #34c759; opacity: 0.85; }
.customer-card.lost { border-left-color: #ff3b30; opacity: 0.7; }

.customer-name { font-weight: 600; color: #566a7f; font-size: 15px; margin-bottom: 8px; }
.customer-value { font-size: 18px; font-weight: 700; color: #696cff; margin-bottom: 8px; }
.customer-meta { font-size: 12px; color: #697a8d; margin: 4px 0; display: flex; align-items: center; gap: 6px; }
.customer-actions { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }

/* Buttons */
.btn-sm { padding: 6px 12px; border-radius: 6px; border: none; font-size: 11px; font-weight: 600; cursor: pointer; transition: 0.2s; }
.btn-qualify { background: rgba(113,221,55,0.15); color: #71dd37; }
.btn-proposal { background: rgba(255,171,0,0.15); color: #ffab00; }
.btn-negotiate { background: rgba(139,92,246,0.15); color: #8b5cf6; }
.btn-won { background: rgba(52,199,89,0.15); color: #34c759; }
.btn-lost { background: rgba(255,59,48,0.15); color: #ff3b30; }
.btn-sm:hover { transform: scale(1.05); }

/* Modal */
.modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center; }
.modal-overlay.active { display: flex; }
.modal { background: #fff; border-radius: 16px; width: 90%; max-width: 500px; max-height: 90vh; overflow-y: auto; padding: 24px; }
.modal h3 { margin: 0 0 20px 0; font-size: 20px; color: #566a7f; }
.form-group { margin-bottom: 16px; }
.form-group label { display: block; font-size: 13px; font-weight: 500; color: #566a7f; margin-bottom: 6px; }
.form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px 12px; border: 1px solid #d9dee3; border-radius: 8px; font-size: 14px; }
.form-group input:focus { outline: none; border-color: #696cff; box-shadow: 0 0 0 3px rgba(105,108,255,0.1); }
.btn-save { width: 100%; padding: 12px; background: #696cff; color: #fff; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; }
.btn-save:hover { background: #5f62e6; }
.btn-close { position: absolute; top: 16px; right: 16px; background: none; border: none; font-size: 24px; cursor: pointer; color: #697a8d; }
.btn-close:hover { color: #566a7f; }

/* Empty state */
.empty-state { text-align: center; padding: 40px 20px; color: #697a8d; }
.empty-state i { font-size: 48px; opacity: 0.3; margin-bottom: 12px; }

@media (max-width: 768px) { .pipeline-board { grid-template-columns: 1fr; } }
</style>

<div class="pipeline-header">
  <h1>🚀 Pipeline de Ventas</h1>
  <p>Gestiona tus oportunidades de negocio</p>
</div>

<div class="pipeline-stats">
  <div class="stat-box"><h3><%= stats.total || 0 %></h3><p>Total</p></div>
  <div class="stat-box"><h3><%= stats.valorPipeline ? '$' + (stats.valorPipeline/1000000).toFixed(1) + 'M' : '$0' %></h3><p>Valor Pipeline</p></div>
  <div class="stat-box"><h3><%= stats.ganados || 0 %></h3><p>Ganados</p></div>
  <div class="stat-box"><h3><%= stats.perdidos || 0 %></h3><p>Perdidos</p></div>
</div>

<div style="margin-bottom: 20px;">
  <button class="btn btn-primary" onclick="openModal()" style="padding: 10px 20px; border-radius: 8px; border: none; background: #696cff; color: #fff; font-weight: 600; cursor: pointer;">
    <i class='bx bx-plus'></i> Nuevo Cliente
  </button>
</div>

<div class="pipeline-board">
  <!-- Prospectos -->
  <div class="pipeline-column">
    <div class="column-header">
      <h3>📋 Prospectos</h3>
      <span class="column-count"><%= customers.filter(c=>c.status==='prospect').length %></span>
    </div>
    <% const prospects = customers.filter(c=>c.status==='prospect'); %>
    <% if (prospects.length === 0) { %>
      <div class="empty-state"><i class='bx bx-user'></i><p>Sin prospectos</p></div>
    <% } else { %>
      <% prospects.forEach(c => { %>
        <div class="customer-card" onclick="editCustomer('<%= c._id %>')">
          <div class="customer-name"><%= c.name %></div>
          <% if (c.value) { %><div class="customer-value"><%= c.value.toLocaleString('es-CO', {style:'currency', currency:'COP', maximumFractionDigits:0}) %></div><% } %>
          <div class="customer-meta"><i class='bx bx-phone'></i> <%= c.phone || 'Sin teléfono' %></div>
          <div class="customer-actions">
            <button class="btn-sm btn-qualify" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'qualified')">✓ Calificar</button>
            <button class="btn-sm btn-lost" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'lost')">✕</button>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Calificados -->
  <div class="pipeline-column">
    <div class="column-header">
      <h3>✅ Calificados</h3>
      <span class="column-count"><%= customers.filter(c=>c.status==='qualified').length %></span>
    </div>
    <% const qualified = customers.filter(c=>c.status==='qualified'); %>
    <% if (qualified.length === 0) { %>
      <div class="empty-state"><i class='bx bx-check-circle'></i><p>Sin calificados</p></div>
    <% } else { %>
      <% qualified.forEach(c => { %>
        <div class="customer-card qualified" onclick="editCustomer('<%= c._id %>')">
          <div class="customer-name"><%= c.name %></div>
          <% if (c.value) { %><div class="customer-value"><%= c.value.toLocaleString('es-CO', {style:'currency', currency:'COP', maximumFractionDigits:0}) %></div><% } %>
          <div class="customer-actions">
            <button class="btn-sm btn-proposal" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'proposal')">📄 Propuesta</button>
            <button class="btn-sm btn-lost" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'lost')">✕</button>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Propuesta -->
  <div class="pipeline-column">
    <div class="column-header">
      <h3>📄 Propuesta</h3>
      <span class="column-count"><%= customers.filter(c=>c.status==='proposal').length %></span>
    </div>
    <% const proposal = customers.filter(c=>c.status==='proposal'); %>
    <% if (proposal.length === 0) { %>
      <div class="empty-state"><i class='bx bx-file'></i><p>Sin propuestas</p></div>
    <% } else { %>
      <% proposal.forEach(c => { %>
        <div class="customer-card proposal" onclick="editCustomer('<%= c._id %>')">
          <div class="customer-name"><%= c.name %></div>
          <% if (c.value) { %><div class="customer-value"><%= c.value.toLocaleString('es-CO', {style:'currency', currency:'COP', maximumFractionDigits:0}) %></div><% } %>
          <div class="customer-actions">
            <button class="btn-sm btn-negotiate" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'negotiation')">💬 Negociar</button>
            <button class="btn-sm btn-won" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'won')">✓</button>
            <button class="btn-sm btn-lost" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'lost')">✕</button>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Negociación -->
  <div class="pipeline-column">
    <div class="column-header">
      <h3>💬 Negociación</h3>
      <span class="column-count"><%= customers.filter(c=>c.status==='negotiation').length %></span>
    </div>
    <% const negotiation = customers.filter(c=>c.status==='negotiation'); %>
    <% if (negotiation.length === 0) { %>
      <div class="empty-state"><i class='bx bx-handshake'></i><p>Sin negociaciones</p></div>
    <% } else { %>
      <% negotiation.forEach(c => { %>
        <div class="customer-card negotiation" onclick="editCustomer('<%= c._id %>')">
          <div class="customer-name"><%= c.name %></div>
          <% if (c.value) { %><div class="customer-value"><%= c.value.toLocaleString('es-CO', {style:'currency', currency:'COP', maximumFractionDigits:0}) %></div><% } %>
          <div class="customer-actions">
            <button class="btn-sm btn-won" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'won')">✓ Ganado</button>
            <button class="btn-sm btn-lost" onclick="event.stopPropagation(); changeStatus('<%= c._id %>', 'lost')">✕ Perdido</button>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Ganados -->
  <div class="pipeline-column">
    <div class="column-header">
      <h3>✓ Ganados</h3>
      <span class="column-count"><%= customers.filter(c=>c.status==='won').length %></span>
    </div>
    <% const won = customers.filter(c=>c.status==='won'); %>
    <% if (won.length === 0) { %>
      <div class="empty-state"><i class='bx bx-trophy'></i><p>¡A ganar más!</p></div>
    <% } else { %>
      <% won.forEach(c => { %>
        <div class="customer-card won" onclick="editCustomer('<%= c._id %>')">
          <div class="customer-name"><%= c.name %></div>
          <% if (c.value) { %><div class="customer-value"><%= c.value.toLocaleString('es-CO', {style:'currency', currency:'COP', maximumFractionDigits:0}) %></div><% } %>
          <span style="font-size:11px; color:#34c759; font-weight:600;">✓ Cerrado</span>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Perdidos -->
  <div class="pipeline-column">
    <div class="column-header">
      <h3>✕ Perdidos</h3>
      <span class="column-count"><%= customers.filter(c=>c.status==='lost').length %></span>
    </div>
    <% const lost = customers.filter(c=>c.status==='lost'); %>
    <% if (lost.length === 0) { %>
      <div class="empty-state"><i class='bx bx-x-circle'></i><p>Sin pérdidas</p></div>
    <% } else { %>
      <% lost.forEach(c => { %>
        <div class="customer-card lost" onclick="editCustomer('<%= c._id %>')">
          <div class="customer-name"><%= c.name %></div>
          <span style="font-size:11px; color:#ff3b30; font-weight:600;">✕ Perdido</span>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<!-- Modal Nuevo/Editar Cliente -->
<div class="modal-overlay" id="customerModal">
  <div class="modal" style="position: relative;">
    <button class="btn-close" onclick="closeModal()">×</button>
    <h3 id="modalTitle">✨ Nuevo Cliente</h3>
    <form id="customerForm" onsubmit="saveCustomer(event)">
      <input type="hidden" id="customerId">
      <div class="form-group">
        <label>Nombre *</label>
        <input type="text" id="custName" required placeholder="Ej: Empresa XYZ">
      </div>
      <div class="form-group">
        <label>Teléfono</label>
        <input type="tel" id="custPhone" placeholder="+57 300 123 4567">
      </div>
      <div class="form-group">
        <label>Valor Estimado (COP)</label>
        <input type="number" id="custValue" placeholder="0">
      </div>
      <div class="form-group">
        <label>Estado</label>
        <select id="custStatus">
          <option value="prospect">📋 Prospecto</option>
          <option value="qualified">✅ Calificado</option>
          <option value="proposal">📄 Propuesta</option>
          <option value="negotiation">💬 Negociación</option>
          <option value="won">✓ Ganado</option>
          <option value="lost">✕ Perdido</option>
        </select>
      </div>
      <div class="form-group">
        <label>Notas</label>
        <textarea id="custNotes" rows="3" placeholder="Detalles adicionales..."></textarea>
      </div>
      <button type="submit" class="btn-save">💾 Guardar Cliente</button>
    </form>
  </div>
</div>

<script>
// Modal functions
function openModal() {
  document.getElementById('modalTitle').textContent = '✨ Nuevo Cliente';
  document.getElementById('customerForm').reset();
  document.getElementById('customerId').value = '';
  document.getElementById('customerModal').classList.add('active');
}
function closeModal() { document.getElementById('customerModal').classList.remove('active'); }
function editCustomer(id) {
  // For now, just open modal - in production fetch data
  document.getElementById('modalTitle').textContent = '✏️ Editar Cliente';
  document.getElementById('customerId').value = id;
  document.getElementById('customerModal').classList.add('active');
}

// Save customer
async function saveCustomer(e) {
  e.preventDefault();
  const id = document.getElementById('customerId').value;
  const data = {
    name: document.getElementById('custName').value,
    phone: document.getElementById('custPhone').value,
    value: parseInt(document.getElementById('custValue').value) || 0,
    status: document.getElementById('custStatus').value,
    notes: document.getElementById('custNotes').value
  };
  
  try {
    const url = id ? `/api/customers/${id}` : '/api/customers';
    const method = id ? 'PUT' : 'POST';
    await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
    location.reload();
  } catch(err) { alert('Error: ' + err.message); }
}

// Change status
async function changeStatus(id, newStatus) {
  if (!confirm(`¿Mover a "${newStatus}"?`)) return;
  try {
    await fetch(`/api/customers/${id}/status`, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ status: newStatus })
    });
    location.reload();
  } catch(err) { alert('Error: ' + err.message); }
}

// Close modal on outside click
document.getElementById('customerModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
