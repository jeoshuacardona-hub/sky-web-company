<script>
function filterLeads() {
  var q = document.getElementById('leadSearch').value.toLowerCase();
  var st = document.getElementById('statusFilter').value;
  document.querySelectorAll('#leadsBody tr').forEach(function(row) {
    var name = row.dataset.name || '';
    var company = row.dataset.company || '';
    var status = row.dataset.status || '';
    var matchQ = !q || name.includes(q) || company.includes(q);
    var matchS = !st || status === st;
    row.style.display = (matchQ && matchS) ? '' : 'none';
  });
}

<% if (isAdmin) { %>
function abrirEditar(btn) {
  document.getElementById('editLeadForm').action = '/leads/edit/' + btn.dataset.id;
  document.getElementById('editName').value = btn.dataset.name;
  document.getElementById('editCompany').value = btn.dataset.company;
  document.getElementById('editPhone').value = btn.dataset.phone;
  document.getElementById('editEmail').value = btn.dataset.email;
  document.getElementById('editCity').value = btn.dataset.city || '';
  document.getElementById('editSource').value = btn.dataset.source || 'otro';
  document.getElementById('editNotes').value = btn.dataset.notes;
  new bootstrap.Modal(document.getElementById('editLeadModal')).show();
}

// Parser CSV robusto en frontend (backup si el backend falla)
function parseCSV(text) {
    if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1); // Remover BOM
    const rows = [];
    let row = [], field = '', inQuotes = false;
    
    for (let i = 0; i < text.length; i++) {
        const c = text[i], next = text[i+1];
        if (c === '"') {
            if (inQuotes && next === '"') { field += '"'; i++; }
            else inQuotes = !inQuotes;
        } else if (c === ',' && !inQuotes) {
            row.push(field.trim()); field = '';
        } else if ((c === '\n' || c === '\r') && !inQuotes) {
            if (field || row.length) { row.push(field.trim()); rows.push(row); row = []; field = ''; }
            if (c === '\r' && next === '\n') i++;
        } else field += c;
    }
    if (field || row.length) { row.push(field.trim()); rows.push(row); }
    return rows.filter(r => r.length > 0 && r.some(v => v));
}

function normalizeHeader(h) {
    const clean = h.toLowerCase().trim().replace(/^"|"$/g, '');
    const map = {
        'nombre':'name','name':'name','nombres':'name','full name':'name',
        'telefono':'phone','teléfono':'phone','phone':'phone','movil':'phone','celular':'phone',
        'email':'email','correo':'email','e-mail':'email','mail':'email',
        'empresa':'company','company':'company','compania':'company',
        'ciudad':'city','city':'city','location':'city',
        'fuente':'source','source':'source','origen':'source',
        'notas':'notes','notes':'notes','observaciones':'notes'
    };
    return map[clean] || clean;
}

function handleDrop(e) {
    e.preventDefault();
    document.getElementById('dropZone').style.borderColor = '#d0d0d8';
    document.getElementById('dropZone').style.background = 'transparent';
    var file = e.dataTransfer.files[0];
    if (file) handleFile(file);
}

function handleFile(file) {
    if (!file) return;
    if (file.type !== 'text/csv' && !file.name.endsWith('.csv')) {
        alert('Por favor selecciona un archivo .csv válido');
        return;
    }
    
    var reader = new FileReader();
    reader.onload = function(e) {
        try {
            var text = e.target.result;
            var rows = parseCSV(text);
            if (rows.length < 2) throw new Error('CSV vacío o sin datos');
            
            var headers = rows[0].map(normalizeHeader);
            var parsedLeads = [];
            
            for (var i = 1; i < rows.length; i++) {
                var obj = {};
                for (var j = 0; j < headers.length; j++) {
                    obj[headers[j]] = rows[i][j] || '';
                }
                // Validar que tenga al menos nombre
                if (obj.name || obj.nombre) {
                    parsedLeads.push({
                        name: obj.name || obj.nombre || '',
                        phone: obj.phone || obj.telefono || obj.celular || '',
                        email: obj.email || obj.correo || '',
                        company: obj.company || obj.empresa || '',
                        city: obj.city || obj.ciudad || '',
                        source: obj.source || obj.fuente || 'csv_import',
                        notes: obj.notes || obj.notas || obj.observaciones || ''
                    });
                }
            }
            
            if (parsedLeads.length === 0) throw new Error('No se encontraron leads válidos (se requiere al menos el nombre)');
            
            // Mostrar preview
            var preview = '<table><thead><tr>';
            headers.slice(0,5).forEach(function(h){ preview += '<th>'+h+'</th>'; });
            preview += '</tr></thead><tbody>';
            parsedLeads.slice(0,5).forEach(function(l){
                preview += '<tr><td>'+l.name+'</td><td>'+l.company+'</td><td>'+l.phone+'</td><td>'+l.city+'</td><td>'+l.source+'</td></tr>';
            });
            preview += '</tbody></table>';
            
            document.getElementById('previewTable').innerHTML = preview;
            document.getElementById('previewCount').textContent = parsedLeads.length;
            document.getElementById('importPreview').style.display = 'block';
            document.getElementById('importBtn').disabled = false;
            window.parsedLeads = parsedLeads;
            
        } catch(err) {
            document.getElementById('importResult').innerHTML = '<div style="background:#fde8e8;border-radius:10px;padding:12px;font-size:13px;color:#b32020;"><i class="bx bx-error-circle me-1"></i>Error: ' + err.message + '</div>';
            document.getElementById('importResult').style.display = 'block';
            document.getElementById('importBtn').disabled = true;
        }
    };
    reader.readAsText(file, 'UTF-8');
}

async function submitImport() {
    if (!window.parsedLeads || window.parsedLeads.length === 0) return;
    
    var btn = document.getElementById('importBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Importando...';
    
    try {
        var res = await fetch('/api/leads/import', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ leads: window.parsedLeads })
        });
        var data = await res.json();
        var el = document.getElementById('importResult');
        
        if (data.success) {
            el.innerHTML = '<div style="background:#e2f8ef;border-radius:10px;padding:12px;font-size:13px;font-weight:600;color:#1a7a50;"><i class="bx bx-check-circle me-1"></i>' + data.message + '</div>';
            el.style.display = 'block';
            setTimeout(function(){ location.reload(); }, 2000);
        } else {
            el.innerHTML = '<div style="background:#fde8e8;border-radius:10px;padding:12px;font-size:13px;color:#b32020;"><i class="bx bx-error-circle me-1"></i>' + (data.message || 'Error al importar') + '</div>';
            el.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = '<i class="bx bx-upload me-1"></i> Importar';
        }
    } catch(err) {
        alert('Error de conexión: ' + err.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="bx bx-upload me-1"></i> Importar';
    }
}
<% } %>
</script>
