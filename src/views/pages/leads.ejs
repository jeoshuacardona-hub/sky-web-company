<style>
.leads-table th { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:#8a8d9f; border-bottom:2px solid #f0f0f0; padding:10px 14px; white-space:nowrap; }
.leads-table td { padding:12px 14px; vertical-align:middle; border-bottom:1px solid #f5f5f5; }
.leads-table tr:last-child td { border-bottom:none; }
.leads-table tr:hover td { background:#fafafa; }
.avatar-sm { width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; flex-shrink:0; }
.status-badge { font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px; white-space:nowrap; }
.status-new { background:#e8eaff; color:#4a50d4; }
.status-contacted { background:#fff0d6; color:#b36800; }
.status-qualified { background:#e8f9fd; color:#0369a1; }
.status-converted { background:#e8faef; color:#166534; }
.status-lost { background:#fff0ee; color:#b32020; }
.stat-pill { background:#fff; border-radius:12px; padding:14px 18px; border:1px solid #f0f0f0; display:flex; align-items:center; gap:12px; flex:1; min-width:160px; }
.search-box { border:1px solid #f0f0f0; border-radius:10px; padding:8px 14px 8px 36px; font-size:13px; width:240px; outline:none; transition:border 0.15s; }
.search-box:focus { border-color:#696cff; }
.csv-preview { max-height:200px; overflow-y:auto; font-size:12px; }
.csv-preview table { width:100%; border-collapse:collapse; }
.csv-preview th, .csv-preview td { padding:6px 8px; border-bottom:1px solid #f0f0f0; text-align:left; }
.csv-preview th { background:#f5f5f5; font-weight:600; font-size:11px; color:#8a8d9f; }
</style>

<%
var colorMap = ['#696cff','#03c3ec','#71dd37','#ff3e1d','#ffab00','#20c997'];
function getInitials(n){ if(!n)return'?'; return n.split(' ').map(function(w){return w[0];}).join('').toUpperCase().slice(0,2); }
function getColor(s){ var h=0; for(var i=0;i<(s||'').length;i++) h=s.charCodeAt(i)+((h<<5)-h); return colorMap[Math.abs(h)%colorMap.length]; }
var isAdmin = typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin';
var totalLeads = leads.length;
var newLeads = leads.filter(function(l){ return l.status==='new'; }).length;
var converted = leads.filter(function(l){ return l.status==='converted'; }).length;
var contacted = leads.filter(function(l){ return l.status==='contacted'; }).length;
%>

<!-- Stats — solo admin -->
<% if (isAdmin) { %>
<div class="d-flex flex-wrap gap-3 mb-4">
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#696cff22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-target-lock" style="font-size:20px;color:#696cff;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Total Leads</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;"><%= totalLeads %></p>
    </div>
  </div>
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#e8eaff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-user-plus" style="font-size:20px;color:#696cff;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Sin Llamar</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#696cff;"><%= newLeads %></p>
    </div>
  </div>
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#fff0d6;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-phone" style="font-size:20px;color:#b36800;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Contactados</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#b36800;"><%= contacted %></p>
    </div>
  </div>
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#e8faef;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-check-circle" style="font-size:20px;color:#166534;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Convertidos</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#166534;"><%= converted %></p>
    </div>
  </div>
</div>
<% } %>

<div class="card" style="border-radius:12px;border:1px solid #f0f0f0;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
  <div class="card-header py-3 px-4" style="background:#fff;border-bottom:1px solid #f0f0f0;border-radius:12px 12px 0 0;">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h6 class="mb-0" style="font-weight:700;">Base de Leads</h6>
        <p class="mb-0" style="font-size:12px;color:#8a8d9f;"><%= totalLeads %> leads en total</p>
      </div>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div style="position:relative;">
          <i class="bx bx-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#8a8d9f;font-size:16px;"></i>
          <input type="text" class="search-box" id="leadSearch" placeholder="Buscar lead..." oninput="filterLeads()">
        </div>
        <select class="form-select form-select-sm" id="statusFilter" style="width:auto;font-size:13px;border-radius:8px;" onchange="filterLeads()">
          <option value="">Todos los estados</option>
          <option value="new">Sin llamar</option>
          <option value="contacted">Contactado</option>
          <option value="qualified">Calificado</option>
          <option value="converted">Convertido</option>
          <option value="lost">Perdido</option>
        </select>
        <% if (isAdmin) { %>
        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#addLeadModal">
          <i class="bx bx-plus me-1"></i> Nuevo
        </button>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#importModal">
          <i class="bx bx-upload me-1"></i> Subir CSV
        </button>
        <% } %>
      </div>
    </div>
  </div>

  <% if (leads.length === 0) { %>
    <div style="text-align:center;padding:56px 0;">
      <i class="bx bx-target-lock" style="font-size:48px;color:#c5c7d4;display:block;margin-bottom:12px;"></i>
      <p style="font-weight:600;color:#5d596c;margin-bottom:4px;">Sin leads aún</p>
      <% if (isAdmin) { %>
      <p style="font-size:13px;color:#c5c7d4;">Sube un CSV o agrega leads manualmente</p>
      <% } else { %>
      <p style="font-size:13px;color:#c5c7d4;">El administrador aún no ha cargado leads</p>
      <% } %>
    </div>
  <% } %>

  <div class="table-responsive">
    <table class="table leads-table mb-0" id="leadsTable">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Empresa</th>
          <th>Teléfono</th>
          <th>Email</th>
          <th>Ciudad</th>
          <th>Fuente</th>
          <th>Estado</th>
          <% if (isAdmin) { %><th style="text-align:right;">Acciones</th><% } %>
        </tr>
      </thead>
      <tbody id="leadsBody">
        <% leads.forEach(function(lead) {
          var initials = getInitials(lead.name);
          var color = getColor(lead.name);
          var statusMap = { new:'Sin llamar', contacted:'Contactado', qualified:'Calificado', converted:'Convertido', lost:'Perdido' };
          var statusCls = { new:'status-new', contacted:'status-contacted', qualified:'status-qualified', converted:'status-converted', lost:'status-lost' };
        %>
        <tr data-name="<%= lead.name.toLowerCase() %>" data-company="<%= (lead.company||'').toLowerCase() %>" data-status="<%= lead.status %>">
          <td>
            <div class="d-flex align-items-center gap-2">
              <div class="avatar-sm" style="background:<%= color %>22;color:<%= color %>;"><%= initials %></div>
              <span style="font-size:13px;font-weight:600;"><%= lead.name %></span>
            </div>
          </td>
          <td style="font-size:13px;color:#8a8d9f;"><%= lead.company || '—' %></td>
          <td style="font-size:13px;"><%= lead.phone || '—' %></td>
          <td style="font-size:13px;color:#8a8d9f;"><%= lead.email || '—' %></td>
          <td style="font-size:13px;color:#8a8d9f;"><%= lead.city || '—' %></td>
          <td style="font-size:13px;color:#8a8d9f;text-transform:capitalize;"><%= lead.source || '—' %></td>
          <td><span class="status-badge <%= statusCls[lead.status] || 'status-new' %>"><%= statusMap[lead.status] || lead.status %></span></td>
          <% if (isAdmin) { %>
          <td style="text-align:right;">
            <div class="d-flex gap-1 justify-content-end">
              <button class="btn btn-sm btn-outline-secondary"
                style="padding:4px 10px;font-size:12px;border-radius:7px;"
                data-id="<%= lead._id %>"
                data-name="<%= lead.name %>"
                data-email="<%= lead.email || '' %>"
                data-phone="<%= lead.phone || '' %>"
                data-company="<%= lead.company || '' %>"
                data-city="<%= lead.city || '' %>"
                data-source="<%= lead.source || '' %>"
                data-notes="<%= (lead.notes||'').replace(/\"/g,'&quot;') %>"
                onclick="abrirEditar(this)">
                <i class="bx bx-edit"></i>
              </button>
              <form action="/leads/delete/<%= lead._id %>" method="POST" style="display:inline;" onsubmit="return confirm('¿Eliminar este lead?')">
                <button type="submit" class="btn btn-sm btn-outline-danger" style="padding:4px 10px;font-size:12px;border-radius:7px;">
                  <i class="bx bx-trash"></i>
                </button>
              </form>
            </div>
          </td>
          <% } %>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

