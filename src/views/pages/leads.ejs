    <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 8px 40px rgba(0,0,0,0.12);">
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <div>
          <h5 class="modal-title mb-0" style="font-weight:700;">Importar CSV</h5>
          <p class="text-muted mb-0" style="font-size:13px;">Columnas soportadas: nombre/name, teléfono/phone, email, empresa/company, ciudad/city, notas/notes</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4 pt-3">
        <div id="dropZone" style="border:2px dashed #d0d0d8;border-radius:12px;padding:32px;text-align:center;cursor:pointer;transition:all 0.15s;" onclick="document.getElementById('csvInput').click()" ondragover="event.preventDefault();this.style.borderColor='#696cff';this.style.background='#f5f5ff'" ondragleave="this.style.borderColor='#d0d0d8';this.style.background='transparent'" ondrop="handleDrop(event)">
          <i class="bx bx-cloud-upload" style="font-size:36px;color:#696cff;display:block;margin-bottom:8px;"></i>
          <p style="font-weight:600;margin:0;font-size:14px;">Arrastra tu CSV aquí</p>
          <p style="font-size:12px;color:#8a8d9f;margin:4px 0 0;">o haz click para seleccionar</p>
          <p style="font-size:11px;color:#c5c7d4;margin-top:8px;">✅ Soporta UTF-8, comillas, y nombres de columna en español/inglés</p>
        </div>
        <input type="file" id="csvInput" accept=".csv,text/csv" style="display:none;" onchange="handleFile(this.files[0])">
        
        <div id="importPreview" style="display:none;margin-top:14px;">
          <p style="font-size:12px;font-weight:600;margin-bottom:6px;">Vista previa (<span id="previewCount">0</span> leads):</p>
          <div class="csv-preview" id="previewTable"></div>
        </div>
        
