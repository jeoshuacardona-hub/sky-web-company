<style>
.pipeline-col { min-width: 260px; width: 260px; flex-shrink: 0; }
.pipeline-header { border-radius: 10px 10px 0 0; padding: 12px 16px; }
.customer-card { background: #fff; border-radius: 10px; border: 1px solid #f0f0f0; padding: 14px; margin-bottom: 10px; cursor: pointer; transition: box-shadow 0.15s, transform 0.15s; }
.customer-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }
.avatar-sm { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; flex-shrink: 0; }
.stage-count { font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
.value-tag { font-size: 11px; font-weight: 600; color: #696cff; background: #f0f0ff; padding: 2px 8px; border-radius: 20px; }
.pipeline-scroll { display: flex; gap: 16px; overflow-x: auto; padding-bottom: 16px; }
.pipeline-scroll::-webkit-scrollbar { height: 6px; }
.pipeline-scroll::-webkit-scrollbar-track { background: #f5f5f5; border-radius: 3px; }
.pipeline-scroll::-webkit-scrollbar-thumb { background: #d0d0d8; border-radius: 3px; }
.add-card-btn { width: 100%; border: 1.5px dashed #d0d0d8; border-radius: 10px; padding: 10px; background: transparent; color: #8a8d9f; font-size: 13px; cursor: pointer; transition: all 0.15s; text-align: center; }
.add-card-btn:hover { border-color: #696cff; color: #696cff; background: #f5f5ff; }
.stat-pill { background: #f5f5ff; border-radius: 10px; padding: 12px 20px; display: flex; align-items: center; gap: 12px; }
</style>

<%
const stages = [
  { key: 'prospect',     label: 'Prospecto',      color: '#8a8d9f', bg: '#f5f5f5' },
  { key: 'qualified',    label: 'Calificado',      color: '#696cff', bg: '#f0f0ff' },
  { key: 'proposal',     label: 'Propuesta',       color: '#03c3ec', bg: '#e8f9fd' },
  { key: 'negotiation',  label: 'Negociación',     color: '#ffab00', bg: '#fff8e6' },
  { key: 'closed-won',   label: 'Cerrado Ganado',  color: '#71dd37', bg: '#f0faeb' },
  { key: 'closed-lost',  label: 'Cerrado Perdido', color: '#ff3e1d', bg: '#fff0ee' }
];
const colorMap = ['#696cff','#03c3ec','#71dd37','#ff3e1d','#ffab00','#20c997'];
function getInitials(name) { if (!name) return '?'; return name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2); }
function getColor(str) { let h=0; for(let i=0;i<(str||'').length;i++) h=str.charCodeAt(i)+((h<<5)-h); return colorMap[Math.abs(h)%colorMap.length]; }
const totalValue = customers.reduce((s,c) => s+(c.value||0), 0);
const wonValue = customers.filter(c=>c.status==='closed-won').reduce((s,c)=>s+(c.value||0),0);
const wonCount = customers.filter(c=>c.status==='closed-won').length;
%>

<!-- Stats -->
<div class="d-flex flex-wrap gap-3 mb-4">
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#696cff22;display:flex;align-items:center;justify-content:center;">
      <i class="bx bx-group" style="font-size:20px;color:#696cff;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:#8a8d9f;">Total Clientes</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;"><%= customers.length %></p>
    </div>
  </div>
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#71dd3722;display:flex;align-items:center;justify-content:center;">
      <i class="bx bx-trophy" style="font-size:20px;color:#71dd37;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:#8a8d9f;">Cerrados Ganados</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#71dd37;"><%= wonCount %></p>
    </div>
  </div>
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#03c3ec22;display:flex;align-items:center;justify-content:center;">
      <i class="bx bx-dollar" style="font-size:20px;color:#03c3ec;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:#8a8d9f;">Valor Pipeline</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;">$<%= totalValue.toLocaleString('es-CO') %></p>
    </div>
  </div>
  <div class="stat-pill">
    <div style="width:38px;height:38px;border-radius:10px;background:#ffab0022;display:flex;align-items:center;justify-content:center;">
      <i class="bx bx-check-circle" style="font-size:20px;color:#ffab00;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:#8a8d9f;">Valor Ganado</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#ffab00;">$<%= wonValue.toLocaleString('es-CO') %></p>
    </div>
  </div>
  <div class="ms-auto d-flex align-items-center">
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCustomerModal">
      <i class="bx bx-plus me-1"></i> Nuevo Cliente
    </button>
  </div>
</div>

<!-- Pipeline Kanban -->
<div class="pipeline-scroll">
  <% stages.forEach(stage => {
    const stageCustomers = customers.filter(c => c.status === stage.key);
    const stageValue = stageCustomers.reduce((s,c)=>s+(c.value||0),0);
  %>
  <div class="pipeline-col">
    <!-- Header -->
    <div style="background:<%= stage.bg %>;border-radius:10px 10px 0 0;padding:12px 16px;border:1px solid <%= stage.color %>22;border-bottom:none;">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
          <span style="width:8px;height:8px;border-radius:50%;background:<%= stage.color %>;display:inline-block;"></span>
          <span style="font-size:13px;font-weight:700;color:<%= stage.color %>;"><%= stage.label %></span>
        </div>
        <span style="font-size:11px;font-weight:700;background:<%= stage.color %>22;color:<%= stage.color %>;padding:2px 8px;border-radius:20px;"><%= stageCustomers.length %></span>
      </div>
      <% if (stageValue > 0) { %>
        <p class="mb-0 mt-1" style="font-size:11px;color:<%= stage.color %>;opacity:0.8;">$<%= stageValue.toLocaleString('es-CO') %></p>
      <% } %>
    </div>
    <!-- Cards -->
    <div style="background:#f9f9fb;border:1px solid #f0f0f0;border-top:none;border-radius:0 0 10px 10px;padding:10px;min-height:200px;">
      <% if (stageCustomers.length === 0) { %>
        <div style="text-align:center;padding:24px 0;color:#c5c7d4;">
          <i class="bx bx-inbox" style="font-size:28px;display:block;margin-bottom:6px;"></i>
          <span style="font-size:12px;">Sin clientes</span>
        </div>
      <% } %>
      <% stageCustomers.forEach(customer => {
        const initials = getInitials(customer.name);
        const color = getColor(customer.name);
      %>
        <div class="customer-card" onclick="openCustomerDetail('<%= customer._id %>', '<%= customer.name %>', '<%= customer.email||'' %>', '<%= customer.phone||'' %>', '<%= customer.company||'' %>', '<%= customer.status %>', '<%= customer.value||0 %>', `<%= (customer.notes||'').replace(/`/g,'') %>`)">
          <div class="d-flex align-items-center gap-2 mb-2">
            <div class="avatar-sm" style="background:<%= color %>22;color:<%= color %>;"><%= initials %></div>
            <div style="min-width:0;">
              <p class="mb-0" style="font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= customer.name %></p>
              <p class="mb-0" style="font-size:11px;color:#8a8d9f;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= customer.company || customer.email || '—' %></p>
            </div>
          </div>
          <% if (customer.phone) { %>
            <p class="mb-1" style="font-size:12px;color:#5d596c;"><i class="bx bx-phone" style="font-size:13px;"></i> <%= customer.phone %></p>
          <% } %>
          <div class="d-flex align-items-center justify-content-between mt-2">
            <% if (customer.value) { %>
              <span class="value-tag">$<%= (customer.value||0).toLocaleString('es-CO') %></span>
            <% } else { %><span></span><% } %>
            <div class="d-flex gap-1">
              <% stages.forEach(s => { if (s.key !== customer.status) { %>
                <form action="/customers/update/<%= customer._id %>" method="POST" class="d-inline">
                  <input type="hidden" name="status" value="<%= s.key %>">
                  <button type="submit" class="btn btn-sm" style="font-size:10px;padding:2px 6px;border-radius:6px;border:1px solid <%= s.color %>44;color:<%= s.color %>;background:transparent;" title="Mover a <%= s.label %>">→ <%= s.label.split(' ')[0] %></button>
                </form>
              <% } }) %>
            </div>
          </div>
        </div>
      <% }) %>
      <button class="add-card-btn mt-1" onclick="openAddWithStatus('<%= stage.key %>')">
        <i class="bx bx-plus"></i> Agregar
      </button>
    </div>
  </div>
  <% }) %>
</div>

<!-- Modal Detalle Cliente -->
<div class="modal fade" id="customerDetailModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 8px 40px rgba(0,0,0,0.12);">
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <div class="d-flex align-items-center gap-3">
          <div id="detailAvatar" class="avatar-sm" style="width:44px;height:44px;font-size:16px;"></div>
          <div>
            <h5 class="modal-title mb-0" id="detailName" style="font-weight:700;"></h5>
            <p class="text-muted mb-0" style="font-size:13px;" id="detailCompany"></p>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4">
        <div class="row g-2 mb-3">
          <div class="col-6"><div style="background:#f9f9fb;border-radius:10px;padding:12px;"><p style="font-size:11px;color:#8a8d9f;margin-bottom:4px;font-weight:600;text-transform:uppercase;">Email</p><p style="font-size:13px;margin:0;" id="detailEmail">—</p></div></div>
          <div class="col-6"><div style="background:#f9f9fb;border-radius:10px;padding:12px;"><p style="font-size:11px;color:#8a8d9f;margin-bottom:4px;font-weight:600;text-transform:uppercase;">Teléfono</p><p style="font-size:13px;margin:0;" id="detailPhone">—</p></div></div>
          <div class="col-6"><div style="background:#f9f9fb;border-radius:10px;padding:12px;"><p style="font-size:11px;color:#8a8d9f;margin-bottom:4px;font-weight:600;text-transform:uppercase;">Valor</p><p style="font-size:13px;margin:0;font-weight:700;color:#696cff;" id="detailValue">—</p></div></div>
          <div class="col-6"><div style="background:#f9f9fb;border-radius:10px;padding:12px;"><p style="font-size:11px;color:#8a8d9f;margin-bottom:4px;font-weight:600;text-transform:uppercase;">Estado</p><p style="font-size:13px;margin:0;" id="detailStatus">—</p></div></div>
        </div>
        <div style="background:#f9f9fb;border-radius:10px;padding:12px;">
          <p style="font-size:11px;color:#8a8d9f;margin-bottom:4px;font-weight:600;text-transform:uppercase;">Notas</p>
          <p style="font-size:13px;margin:0;" id="detailNotes">Sin notas</p>
        </div>
      </div>
      <div class="modal-footer border-0 px-4 pb-4 pt-2 d-flex justify-content-between">
        <form id="deleteCustomerForm" method="POST">
          <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Eliminar este cliente?')"><i class="bx bx-trash me-1"></i> Eliminar</button>
        </form>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Nuevo Cliente -->
<div class="modal fade" id="addCustomerModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 8px 40px rgba(0,0,0,0.12);">
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <div><h5 class="modal-title mb-0" style="font-weight:700;">Nuevo Cliente</h5><p class="text-muted mb-0" style="font-size:13px;">Agrega un cliente al pipeline</p></div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/customers/add" method="POST">
        <div class="modal-body px-4 pt-3">
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label fw-semibold" style="font-size:13px;">Nombre *</label><input type="text" name="name" class="form-control" placeholder="María López" required /></div>
            <div class="col-md-6"><label class="form-label fw-semibold" style="font-size:13px;">Empresa</label><input type="text" name="company" class="form-control" placeholder="Empresa S.A.S" /></div>
            <div class="col-md-6"><label class="form-label fw-semibold" style="font-size:13px;">Email</label><input type="email" name="email" class="form-control" placeholder="maria@empresa.com" /></div>
            <div class="col-md-6"><label class="form-label fw-semibold" style="font-size:13px;">Teléfono</label><input type="text" name="phone" class="form-control" placeholder="+57 300 000 0000" /></div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" style="font-size:13px;">Estado</label>
              <select name="status" id="addStatusSelect" class="form-select">
                <option value="prospect">Prospecto</option>
                <option value="qualified">Calificado</option>
                <option value="proposal">Propuesta</option>
                <option value="negotiation">Negociación</option>
                <option value="closed-won">Cerrado Ganado</option>
                <option value="closed-lost">Cerrado Perdido</option>
              </select>
            </div>
            <div class="col-md-6"><label class="form-label fw-semibold" style="font-size:13px;">Valor Estimado ($)</label><input type="number" name="value" class="form-control" placeholder="0" /></div>
            <div class="col-12"><label class="form-label fw-semibold" style="font-size:13px;">Notas</label><textarea name="notes" class="form-control" rows="3" placeholder="Información adicional..."></textarea></div>
          </div>
        </div>
        <div class="modal-footer border-0 px-4 pb-4 pt-2">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary px-4">Guardar Cliente</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
const stageLabels = { prospect:'Prospecto', qualified:'Calificado', proposal:'Propuesta', negotiation:'Negociación', 'closed-won':'Cerrado Ganado', 'closed-lost':'Cerrado Perdido' };
const colorMap = ['#696cff','#03c3ec','#71dd37','#ff3e1d','#ffab00','#20c997'];
function getColor(str) { let h=0; for(let i=0;i<(str||'').length;i++) h=str.charCodeAt(i)+((h<<5)-h); return colorMap[Math.abs(h)%colorMap.length]; }
function getInitials(name) { if (!name) return '?'; return name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2); }

function openCustomerDetail(id, name, email, phone, company, status, value, notes) {
  const color = getColor(name);
  document.getElementById('detailAvatar').style.background = color + '22';
  document.getElementById('detailAvatar').style.color = color;
  document.getElementById('detailAvatar').textContent = getInitials(name);
  document.getElementById('detailName').textContent = name;
  document.getElementById('detailCompany').textContent = company || '—';
  document.getElementById('detailEmail').textContent = email || '—';
  document.getElementById('detailPhone').textContent = phone || '—';
  document.getElementById('detailValue').textContent = value > 0 ? '$' + parseInt(value).toLocaleString('es-CO') : '—';
  document.getElementById('detailStatus').textContent = stageLabels[status] || status;
  document.getElementById('detailNotes').textContent = notes || 'Sin notas';
  document.getElementById('deleteCustomerForm').action = '/customers/delete/' + id;
  new bootstrap.Modal(document.getElementById('customerDetailModal')).show();
}

function openAddWithStatus(status) {
  document.getElementById('addStatusSelect').value = status;
  new bootstrap.Modal(document.getElementById('addCustomerModal')).show();
}
</script>
