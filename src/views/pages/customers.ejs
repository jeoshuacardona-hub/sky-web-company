<style>
.customer-card { background:#fff; border-radius:12px; border:1px solid #f0f0f0; padding:16px; margin-bottom:10px; transition:box-shadow 0.15s; }
.customer-card:hover { box-shadow:0 4px 14px rgba(0,0,0,0.07); }
.avatar-sm { width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; flex-shrink:0; }
.stat-sm { background:#fff; border-radius:12px; padding:14px 18px; border:1px solid #f0f0f0; display:flex; align-items:center; gap:12px; }
.badge-prospect { background:#e8eaff; color:#4a50d4; font-size:11px; font-weight:600; padding:2px 10px; border-radius:20px; }
.badge-qualified { background:#fff0d6; color:#b36800; font-size:11px; font-weight:600; padding:2px 10px; border-radius:20px; }
.badge-closed_won { background:#e8faef; color:#166534; font-size:11px; font-weight:600; padding:2px 10px; border-radius:20px; }
.badge-closed_lost { background:#fff0ee; color:#b32020; font-size:11px; font-weight:600; padding:2px 10px; border-radius:20px; }
</style>

<%
var colorMap = ['#696cff','#03c3ec','#71dd37','#ff3e1d','#ffab00','#20c997'];
function getInitials(name){ if(!name)return'?'; return name.split(' ').map(function(w){return w[0];}).join('').toUpperCase().slice(0,2); }
function getColor(str){ var h=0; for(var i=0;i<(str||'').length;i++) h=str.charCodeAt(i)+((h<<5)-h); return colorMap[Math.abs(h)%colorMap.length]; }
var statusMap = { prospect:'Prospecto', qualified:'Calificado', proposal:'Propuesta', negotiation:'Negociación', closed_won:'Ganado', closed_lost:'Perdido' };
var statusCls = { prospect:'badge-prospect', qualified:'badge-qualified', closed_won:'badge-closed_won', closed_lost:'badge-closed_lost' };
var totalValue = customers.reduce(function(acc, c){ return acc + (c.value || 0); }, 0);
%>

<div class="d-flex flex-wrap gap-3 mb-4">
  <div class="stat-sm">
    <div style="width:38px;height:38px;border-radius:10px;background:#696cff22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-briefcase" style="font-size:20px;color:#696cff;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Total Clientes</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;"><%= customers.length %></p>
    </div>
  </div>
  <div class="stat-sm">
    <div style="width:38px;height:38px;border-radius:10px;background:#e8faef;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bx bx-dollar-circle" style="font-size:20px;color:#166534;"></i>
    </div>
    <div>
      <p class="mb-0" style="font-size:11px;font-weight:600;text-transform:uppercase;color:#8a8d9f;">Valor Pipeline</p>
      <p class="mb-0" style="font-size:22px;font-weight:700;color:#166534;">$<%= totalValue.toLocaleString() %></p>
    </div>
  </div>
</div>

<div class="card" style="border-radius:12px;border:1px solid #f0f0f0;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
  <div class="card-header py-3 px-4" style="background:#fff;border-bottom:1px solid #f0f0f0;border-radius:12px 12px 0 0;">
    <div>
      <h6 class="mb-0" style="font-weight:700;">Pipeline de Clientes</h6>
      <p class="mb-0" style="font-size:12px;color:#8a8d9f;">Oportunidades agendadas y en proceso</p>
    </div>
  </div>

  <% if (customers.length === 0) { %>
    <div style="text-align:center;padding:56px 0;">
      <i class="bx bx-briefcase" style="font-size:48px;color:#c5c7d4;display:block;margin-bottom:12px;"></i>
      <p style="font-weight:600;color:#5d596c;margin-bottom:4px;">Pipeline vacío</p>
      <p style="font-size:13px;color:#c5c7d4;">Agenda reuniones desde Llamadas para ver clientes aquí</p>
    </div>
  <% } %>

  <div class="px-4 py-3">
    <% customers.forEach(function(c) {
      var initials = getInitials(c.name);
      var color = getColor(c.name);
      var statusLabel = statusMap[c.status] || c.status;
      var badgeClass = statusCls[c.status] || 'badge-prospect';
    %>
    <div class="customer-card" id="customer-<%= c._id %>">
      <div class="d-flex align-items-start gap-3">
        <div class="avatar-sm mt-1" style="background:<%= color %>22;color:<%= color %>;"><%= initials %></div>
        <div style="flex:1;min-width:0;">
          <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
            <p class="mb-0" style="font-size:14px;font-weight:700;"><%= c.name %></p>
            <span class="<%= badgeClass %>"><%= statusLabel %></span>
          </div>
          <div class="d-flex gap-3 flex-wrap mb-2">
            <% if (c.company) { %><span style="font-size:12px;color:#8a8d9f;"><i class="bx bx-buildings" style="font-size:12px;"></i> <%= c.company %></span><% } %>
            <% if (c.phone) { %><span style="font-size:12px;color:#5d596c;"><i class="bx bx-phone" style="font-size:12px;"></i> <%= c.phone %></span><% } %>
            <% if (c.value) { %><span style="font-size:12px;color:#166534;font-weight:600;"><i class="bx bx-dollar" style="font-size:12px;"></i> $<%= c.value.toLocaleString() %></span><% } %>
          </div>
          <% if (c.notes) { %>
            <p style="font-size:12px;color:#8a8d9f;margin:0;"><strong>Notas:</strong> <%= c.notes %></p>
          <% } %>
        </div>
        <div class="d-flex flex-column gap-2 flex-shrink-0">
          <% if (c.status !== 'closed_lost' && c.status !== 'closed_won') { %>
          <select class="form-select form-select-sm" style="width:auto;font-size:12px;" onchange="updatePipelineStatus('<%= c._id %>', this.value)">
            <option value="prospect" <%= c.status==='prospect'?'selected':'' %>>Prospecto</option>
            <option value="qualified" <%= c.status==='qualified'?'selected':'' %>>Calificado</option>
            <option value="proposal" <%= c.status==='proposal'?'selected':'' %>>Propuesta</option>
            <option value="negotiation" <%= c.status==='negotiation'?'selected':'' %>>Negociación</option>
            <option value="closed_won" <%= c.status==='closed_won'?'selected':'' %>>Ganado</option>
            <option value="closed_lost" <%= c.status==='closed_lost'?'selected':'' %>>Perdido</option>
          </select>
          <% } %>
          <button class="btn btn-sm btn-outline-danger" style="padding:3px 8px;font-size:12px;" onclick="eliminarDePipeline('<%= c._id %>', '<%= c.name %>')">
            <i class="bx bx-trash"></i> Eliminar (Ir a Seguimiento)
          </button>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<script>
async function updatePipelineStatus(customerId, status) {
  try {
    var res = await fetch('/api/pipeline/' + customerId + '/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: status })
    });
    var data = await res.json();
    if (data.success) location.reload();
  } catch(e) { alert('Error actualizando.'); }
}

async function eliminarDePipeline(id, name) {
  if (!confirm('¿Eliminar ' + name + ' del Pipeline?\nSe enviará automáticamente a Seguimiento para no perder el lead.')) return;
  try {
    var res = await fetch('/api/pipeline/' + id + '/delete', { method: 'POST' });
    var data = await res.json();
    if (data.success) {
      alert(data.message);
      location.reload();
    }
  } catch(e) { alert('Error eliminando.'); }
}
</script>
