<div class="page-header">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Bienvenido de nuevo, <%= currentUser.fullName || currentUser.username %></p>
  </div>
  <button class="btn btn-primary" onclick="location.href='/leads/new'">
    <i class='bx bx-plus'></i>
    Nuevo Lead
  </button>
</div>

<div class="stats-grid">
  <div class="stat-card fade-in">
    <div class="stat-value"><%= stats.totalLeads || 0 %></div>
    <div class="stat-label">Total Leads</div>
  </div>
  <div class="stat-card fade-in" style="animation-delay: 0.1s">
    <div class="stat-value"><%= stats.newLeads || 0 %></div>
    <div class="stat-label">Leads Nuevos</div>
  </div>
  <div class="stat-card fade-in" style="animation-delay: 0.2s">
    <div class="stat-value"><%= stats.callsToday || 0 %></div>
    <div class="stat-label">Llamadas Hoy</div>
  </div>
  <div class="stat-card fade-in" style="animation-delay: 0.3s">
    <div class="stat-value"><%= stats.pendingTasks || 0 %></div>
    <div class="stat-label">Tareas Pendientes</div>
  </div>
</div>

<div class="grid grid-2">
  <div class="card fade-in" style="animation-delay: 0.4s">
    <div class="card-header">
      <h2 class="card-title">Actividad Reciente</h2>
    </div>
    <p class="text-secondary">Tu actividad aparecerá aquí</p>
  </div>
  
  <div class="card fade-in" style="animation-delay: 0.5s">
    <div class="card-header">
      <h2 class="card-title">Próximas Reuniones</h2>
    </div>
    <p class="text-secondary">No hay reuniones programadas</p>
  </div>
</div>
