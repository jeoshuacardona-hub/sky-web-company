<div class="auth-logo">
  <i class='bx bx-cloud'></i>
  <h2>Sky Web Company</h2>
  <p>Inicia sesión en tu cuenta</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div style="background: #fed7d7; color: #c53030; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 14px;">
    <%= error %>
  </div>
<% } %>

<form action="/login" method="POST">
  <div class="form-group">
    <label class="form-label">EMAIL O USUARIO</label>
    <input type="text" name="username" class="form-input" placeholder="Ingresa tu email" required>
  </div>
  
  <div class="form-group">
    <label class="form-label">CONTRASEÑA</label>
    <input type="password" name="password" class="form-input" placeholder="••••••••" required>
  </div>
  
  <button type="submit" class="btn-login">
    <i class='bx bx-log-in' style="margin-right: 8px;"></i>Entrar
  </button>
</form>
