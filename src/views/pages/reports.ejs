<style>
.report-card { background:#fff; border-radius:12px; padding:24px; border:1px solid #f0f2f4; margin-bottom:20px; }
.stat-big { text-align:center; padding:20px; }
.stat-big-value { font-size:42px; font-weight:700; color:#696cff; margin-bottom:8px; }
.stat-big-label { font-size:13px; color:#697a8d; text-transform:uppercase; letter-spacing:0.5px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 style="font-size:24px; font-weight:700; color:#566a7f; margin:0;">
      <i class='bx bx-bar-chart-alt-2 me-2'></i>Reportes
    </h2>
    <p style="color:#697a8d; margin:4px 0 0 0; font-size:14px;">Análisis y métricas de rendimiento</p>
  </div>
  <button class="btn btn-outline-primary" id="btnExportPdf">
    <i class='bx bx-download me-1'></i> Exportar PDF
  </button>
</div>

<!-- Stats Principales -->
<div class="row mb-4">
  <div class="col-md-3 col-sm-6">
    <div class="report-card stat-big">
      <div class="stat-big-value"><%= stats && stats.totalLeads ? stats.totalLeads : 0 %></div>
      <div class="stat-big-label">Total Leads</div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="report-card stat-big" style="background:linear-gradient(135deg,#71dd37,#55c92a); color:#fff; border:none;">
      <div class="stat-big-value" style="color:#fff;"><%= stats && stats.convertedLeads ? stats.convertedLeads : 0 %></div>
      <div class="stat-big-label" style="color:rgba(255,255,255,0.9);">Convertidos</div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="report-card stat-big">
      <div class="stat-big-value" style="color:#ffab00;"><%= stats && stats.conversionRate ? stats.conversionRate : 0 %>%</div>
      <div class="stat-big-label">Tasa Conversión</div>
    </div>
  </div>
  <div class="col-md-3 col-sm-6">
    <div class="report-card stat-big">
      <div class="stat-big-value" style="color:#16a34a;">$<%= stats && stats.revenue ? (stats.revenue/1000000).toFixed(1) : '0.0' %>M</div>
      <div class="stat-big-label">Ingresos</div>
    </div>
  </div>
</div>

<div class="row">
  <!-- Resumen de Leads -->
  <div class="col-md-6 mb-4">
    <div class="report-card">
      <h5 style="font-weight:700; margin-bottom:20px; color:#566a7f;">
        <i class='bx bx-target-lock me-2'></i>Resumen de Leads
      </h5>
      <% 
        var s = stats || {};
        var total = s.totalLeads || 0;
        var contacted = s.contactedLeads || 0;
        var converted = s.convertedLeads || 0;
        var lost = s.lostLeads || 0;
      %>
      <div class="mb-3">
        <div class="d-flex justify-content-between mb-2">
          <span style="font-size:13px; color:#697a8d;">Contactados</span>
          <strong style="color:#566a7f;"><%= contacted %></strong>
        </div>
        <div style="background:#f0f2f4; height:8px; border-radius:4px;">
          <div style="background:#03c3ec; height:100%; border-radius:4px; width:<%= total > 0 ? (contacted/total*100) : 0 %>%; transition:width 0.5s;"></div>
        </div>
      </div>
      <div class="mb-3">
        <div class="d-flex justify-content-between mb-2">
          <span style="font-size:13px; color:#697a8d;">Convertidos</span>
          <strong style="color:#566a7f;"><%= converted %></strong>
        </div>
        <div style="background:#f0f2f4; height:8px; border-radius:4px;">
          <div style="background:#71dd37; height:100%; border-radius:4px; width:<%= total > 0 ? (converted/total*100) : 0 %>%; transition:width 0.5s;"></div>
        </div>
      </div>
      <div class="mb-3">
        <div class="d-flex justify-content-between mb-2">
          <span style="font-size:13px; color:#697a8d;">Perdidos</span>
          <strong style="color:#566a7f;"><%= lost %></strong>
        </div>
        <div style="background:#f0f2f4; height:8px; border-radius:4px;">
          <div style="background:#ff3e1d; height:100%; border-radius:4px; width:<%= total > 0 ? (lost/total*100) : 0 %>%; transition:width 0.5s;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Actividad -->
  <div class="col-md-6 mb-4">
    <div class="report-card">
      <h5 style="font-weight:700; margin-bottom:20px; color:#566a7f;">
        <i class='bx bx-phone me-2'></i>Actividad del Mes
      </h5>
      <div class="d-flex justify-content-around text-center">
        <div>
          <div style="font-size:36px; font-weight:700; color:#696cff; margin-bottom:8px;"><%= s.callsThisMonth || 0 %></div>
          <div style="font-size:12px; color:#697a8d;">Llamadas</div>
        </div>
        <div style="border-left:1px solid #f0f2f4; margin:0 20px;"></div>
        <div>
          <div style="font-size:36px; font-weight:700; color:#71dd37; margin-bottom:8px;"><%= s.wonCustomers || 0 %></div>
          <div style="font-size:12px; color:#697a8d;">Clientes</div>
        </div>
        <div style="border-left:1px solid #f0f2f4; margin:0 20px;"></div>
        <div>
          <div style="font-size:36px; font-weight:700; color:#ffab00; margin-bottom:8px;"><%= s.totalCustomers || 0 %></div>
          <div style="font-size:12px; color:#697a8d;">Total</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Resumen Final -->
<div class="report-card">
  <h5 style="font-weight:700; margin-bottom:16px; color:#566a7f;">
    <i class='bx bx-info-circle me-2'></i>Resumen General
  </h5>
  <div class="row">
    <div class="col-md-3 col-sm-6 mb-3">
      <div style="padding:16px; background:#f8f9fa; border-radius:8px; text-align:center;">
        <div style="font-size:24px; font-weight:700; color:#566a7f; margin-bottom:4px;">
          <%= total > 0 ? ((contacted/total*100).toFixed(0)) : 0 %>%
        </div>
        <div style="font-size:11px; color:#697a8d;">Tasa Contacto</div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
      <div style="padding:16px; background:#f8f9fa; border-radius:8px; text-align:center;">
        <div style="font-size:24px; font-weight:700; color:#566a7f; margin-bottom:4px;">
          $<%= (s.totalCustomers || 0) > 0 ? (s.revenue / s.totalCustomers).toFixed(0) : 0 %>
        </div>
        <div style="font-size:11px; color:#697a8d;">Ticket Promedio</div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
      <div style="padding:16px; background:#f8f9fa; border-radius:8px; text-align:center;">
        <div style="font-size:24px; font-weight:700; color:#566a7f; margin-bottom:4px;">
          <%= s.wonCustomers || 0 %>
        </div>
        <div style="font-size:11px; color:#697a8d;">Clientes Ganados</div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
      <div style="padding:16px; background:#f8f9fa; border-radius:8px; text-align:center;">
        <div style="font-size:24px; font-weight:700; color:#566a7f; margin-bottom:4px;">
          <%= lost %>
        </div>
        <div style="font-size:11px; color:#697a8d;">Leads Perdidos</div>
      </div>
    </div>
  </div>
</div>

<!-- Comisiones por Usuario (Solo Admin) -->
<% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
<div class="report-card mt-4">
  <h5 style="font-weight:700; margin-bottom:16px; color:#566a7f;">
    <i class='bx bx-user-check me-2'></i>Comisiones por Usuario
  </h5>
  <div style="overflow-x:auto;">
    <table style="width:100%; border-collapse:collapse; font-size:13px;">
      <thead>
        <tr style="background:#f8f9fa; text-align:left;">
          <th style="padding:12px; border-bottom:1px solid #e4e6eb;">Usuario</th>
          <th style="padding:12px; border-bottom:1px solid #e4e6eb;">Llamadas</th>
          <th style="padding:12px; border-bottom:1px solid #e4e6eb;">Reuniones</th>
          <th style="padding:12px; border-bottom:1px solid #e4e6eb;">Ventas</th>
        </tr>
      </thead>
      <tbody id="comisionesBody">
        <tr><td colspan="4" style="padding:20px; text-align:center; color:#697a8d;">Cargando...</td></tr>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Script seguro para PDF -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script>
// Datos seguros pasados desde EJS (sin tags dentro de strings JS)
var reportData = {
  totalLeads: <%= JSON.stringify(stats && stats.totalLeads || 0) %>,
  contactedLeads: <%= JSON.stringify(stats && stats.contactedLeads || 0) %>,
  convertedLeads: <%= JSON.stringify(stats && stats.convertedLeads || 0) %>,
  lostLeads: <%= JSON.stringify(stats && stats.lostLeads || 0) %>,
  totalCustomers: <%= JSON.stringify(stats && stats.totalCustomers || 0) %>,
  wonCustomers: <%= JSON.stringify(stats && stats.wonCustomers || 0) %>,
  revenue: <%= JSON.stringify(stats && stats.revenue || 0) %>,
  callsThisMonth: <%= JSON.stringify(stats && stats.callsThisMonth || 0) %>,
  conversionRate: <%= JSON.stringify(stats && stats.conversionRate || 0) %>,
  userName: <%= JSON.stringify(currentUser && currentUser.fullName || 'Administrador') %>
};

// Función PDF simple y segura
function exportarReportePDF() {
  if (typeof window.jspdf === 'undefined') {
    alert('Cargando librería PDF, inténtalo en 3 segundos...');
    return;
  }
  
  var doc = new window.jspdf.jsPDF();
  var y = 25;
  var pw = doc.internal.pageSize.getWidth();
  
  // Header
  doc.setFillColor(105, 108, 255);
  doc.rect(0, 0, pw, 30, 'F');
  doc.setTextColor(255, 255, 255);
  doc.setFontSize(20);
  doc.setFont('helvetica', 'bold');
  doc.text('Sky Web - Reporte Comercial', pw/2, 18, {align:'center'});
  doc.setFontSize(9);
  doc.setFont('helvetica', 'normal');
  doc.text('Generado: ' + new Date().toLocaleString('es-CO'), pw/2, 26, {align:'center'});
  
  y = 45;
  doc.setTextColor(0, 0, 0);
  
  function sec(titulo, lineas) {
    if (y > 260) { doc.addPage(); y = 20; }
    doc.setFontSize(12);
    doc.setFont('helvetica', 'bold');
    doc.setFillColor(240, 242, 244);
    doc.rect(15, y-4, pw-30, 10, 'F');
    doc.text(titulo, 20, y);
    y += 12;
    doc.setFontSize(9);
    doc.setFont('helvetica', 'normal');
    for (var i = 0; i < lineas.length; i++) {
      if (y > 270) { doc.addPage(); y = 20; }
      doc.text(lineas[i], 20, y);
      y += 5;
    }
    y += 4;
  }
  
  var d = reportData;
  var contactPct = d.totalLeads > 0 ? (d.contactedLeads/d.totalLeads*100).toFixed(1) : 0;
  var ticket = d.totalCustomers > 0 ? (d.revenue/d.totalCustomers).toLocaleString('es-CO') : '0';
  
  sec('RESUMEN EJECUTIVO', [
    'Reporte de rendimiento comercial de Sky Web.',
    'Periodo: Mes actual | Generado por: ' + d.userName
  ]);
  
  sec('METRICAS DE LEADS', [
    'Total Leads: ' + d.totalLeads + ' (clientes potenciales)',
    'Contactados: ' + d.contactedLeads + ' (' + contactPct + '% con comunicacion)',
    'Convertidos: ' + d.convertedLeads + ' (' + d.conversionRate + '% tasa de exito)',
    'Perdidos: ' + d.lostLeads + ' (no continuaron)'
  ]);
  
  sec('INGRESOS Y CLIENTES', [
    'Clientes Totales: ' + d.totalCustomers,
    'Clientes Ganados: ' + d.wonCustomers + ' (ventas cerradas)',
    'Ingresos: $' + d.revenue.toLocaleString('es-CO') + ' COP',
    'Ticket Promedio: $' + ticket + ' COP'
  ]);
  
  sec('ACTIVIDAD DEL MES', [
    'Llamadas: ' + d.callsThisMonth,
    'Conversion: ' + d.conversionRate + '% = (Convertidos/Total)*100'
  ]);
  
  sec('RECOMENDACIONES', [
    '>20% conversion: Excelente | 10-20%: Aceptable | <10%: Optimizar',
    '- Contactar leads en primeras 24h',
    '- Up-selling con clientes convertidos',
    '- Analizar causas de leads perdidos'
  ]);
  
  // Footer
  var pg = doc.internal.getNumberOfPages();
  for (var i = 1; i <= pg; i++) {
    doc.setPage(i);
    doc.setFontSize(7);
    doc.setTextColor(150);
    doc.text('Sky Web - Confidencial - Pag ' + i + ' de ' + pg, pw/2, 290, {align:'center'});
  }
  
  doc.save('Reporte-SkyWeb-' + new Date().toISOString().slice(0,10) + '.pdf');
}

// Vincular botón
document.getElementById('btnExportPdf').addEventListener('click', exportarReportePDF);

// Cargar comisiones (solo admin)
<% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
async function loadComisiones() {
  try {
    var res = await fetch('/api/reports/commissions');
    if (!res.ok) throw new Error('Error ' + res.status);
    var data = await res.json();
    var tbody = document.getElementById('comisionesBody');
    if (!data.success || !data.users || data.users.length === 0) {
      tbody.innerHTML = '<tr><td colspan="4" style="padding:20px; text-align:center; color:#697a8d;">Sin datos</td></tr>';
      return;
    }
    tbody.innerHTML = data.users.map(function(u) {
      var name = u.fullName || u.username || 'Sin nombre';
      var calls = u.calls || 0;
      var meetings = u.meetings || 0;
      var revenue = u.revenue || 0;
      return '<tr style="border-bottom:1px solid #f0f2f4;">' +
        '<td style="padding:12px; font-weight:500;">' + name + '</td>' +
        '<td style="padding:12px;">' + calls + '</td>' +
        '<td style="padding:12px;">' + meetings + '</td>' +
        '<td style="padding:12px; color:#16a34a; font-weight:600;">$' + (revenue/1000000).toFixed(1) + 'M</td>' +
        '</tr>';
    }).join('');
  } catch(e) {
    console.error('Error loading commissions', e);
    document.getElementById('comisionesBody').innerHTML = '<tr><td colspan="4" style="padding:20px; text-align:center; color:#ff3e1d;">Error al cargar</td></tr>';
  }
}
document.addEventListener('DOMContentLoaded', loadComisiones);
<% } %>
</script>

<!-- FIX: Script mínimo para que el botón PDF funcione -->
<script>
// Función ultra-simple para exportar PDF
function exportarPDFSimple() {
  // Crear documento básico
  var doc = new jsPDF();
  
  // Título
  doc.setFontSize(18);
  doc.text('Sky Web - Reporte', 20, 20);
  
  // Fecha
  doc.setFontSize(11);
  doc.text('Generado: ' + new Date().toLocaleString('es-CO'), 20, 30);
  
  // Línea separadora
  doc.line(20, 35, 190, 35);
  
  // Contenido básico con los datos visibles en pantalla
  var y = 50;
  doc.setFontSize(12);
  
  // Leer datos de las tarjetas de stats (si existen en el DOM)
  var stats = document.querySelectorAll('.stat-big-value');
  var labels = document.querySelectorAll('.stat-big-label');
  
  doc.text('Metricas Principales:', 20, y);
  y += 10;
  doc.setFontSize(10);
  
  for (var i = 0; i < Math.min(stats.length, 4); i++) {
    if (y > 270) { doc.addPage(); y = 20; }
    var label = labels[i] ? labels[i].textContent.trim() : 'Dato';
    var value = stats[i] ? stats[i].textContent.trim() : '0';
    doc.text(label + ': ' + value, 20, y);
    y += 7;
  }
  
  // Footer
  doc.setFontSize(8);
  doc.setTextColor(100);
  doc.text('Sky Web - Documento generado automáticamente', 20, 285);
  
  // Guardar
  doc.save('SkyWeb-Reporte-' + new Date().toISOString().slice(0,10) + '.pdf');
}

// Reemplazar el onclick del botón existente
var btn = document.getElementById('btnExportPdf');
if (btn) {
  btn.onclick = function(e) {
    e.preventDefault();
    // Si jsPDF no está cargado, cargarlo primero
    if (typeof jsPDF === 'undefined') {
      var script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
      script.onload = function() {
        // Esperar un poco para que jsPDF se inicialice
        setTimeout(exportarPDFSimple, 500);
      };
      document.head.appendChild(script);
      btn.innerHTML = '<i class="bx bx-loader bx-spin me-1"></i> Cargando...';
    } else {
      exportarPDFSimple();
    }
  };
}
</script>
